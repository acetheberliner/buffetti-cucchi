---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { productCategories } from '../../data/catalog';
import { site } from '../../data/site';
import { ArrowRight, MapPin, Phone } from '@lucide/astro';

export function getStaticPaths() {
  return productCategories.map((category) => ({
    params: { slug: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const relatedCategories = productCategories.filter((item) => item.slug !== category.slug).slice(0, 4);
const visualPools = {
  'arredo-complementi': [
    '/images/arredamento/product/sedute-operative.svg',
    '/images/arredamento/product/lampade-organizer.svg',
    '/images/arredamento/brand/postazioni-lavoro.svg',
    '/images/arredamento/brand/ergonomia.svg',
  ],
  'carta-modulistica': [
    '/images/cancelleria/carta-buffetti-gialla.png',
    '/images/cancelleria/carta-buffetti-rosa.png',
    '/images/cancelleria/brand/archiviazione.png',
    '/images/scuola/product/quaderni-diari.svg',
  ],
  'cartucce-toner': [
    '/images/ufficio/product/toner-cartucce.svg',
    '/images/ufficio/brand/macchine-ufficio.svg',
  ],
  archiviazione: [
    '/images/ufficio/product/archivio-ufficio.svg',
    '/images/cancelleria/brand/archiviazione.png',
  ],
  cancelleria: [
    '/images/cancelleria/brand/scrittura.png',
    '/images/cancelleria/carta-buffetti-gialla.png',
    '/images/scuola/brand/quaderni.svg',
    '/images/ufficio/brand/accessori-scrivania.svg',
  ],
  'disegno-didattica': [
    '/images/scuola/brand/colori.svg',
    '/images/scuola/brand/disegno-tecnico.svg',
    '/images/scuola/product/zaini-astucci.svg',
    '/images/scuola/product/quaderni-diari.svg',
  ],
  'visual-comunicazione': [
    '/images/ufficio/brand/accessori-scrivania.svg',
    '/images/arredamento/brand/postazioni-lavoro.svg',
  ],
  'comunita-servizi': [
    '/images/servizi/product/stampa-spedizioni.svg',
    '/images/servizi/brand/fotocopie.svg',
  ],
  'spedizione-imballaggi': [
    '/images/servizi/brand/spedizioni.svg',
    '/images/servizi/product/stampa-spedizioni.svg',
  ],
  'informatica-elettronica': [
    '/images/ufficio/brand/macchine-ufficio.svg',
    '/images/ufficio/product/toner-cartucce.svg',
  ],
  'macchine-ufficio': [
    '/images/ufficio/brand/macchine-ufficio.svg',
    '/images/servizi/product/stampa-spedizioni.svg',
  ],
  ecosostenibili: [
    '/images/cancelleria/brand/archiviazione.png',
    '/images/cancelleria/carta-buffetti-gialla.png',
  ],
};
const imagePool = visualPools[category.slug] ?? [category.image];
const itemTone = {
  'arredo-complementi': 'per rendere piu comoda e ordinata la postazione',
  'carta-modulistica': 'per stampare, scrivere, archiviare e gestire pratiche',
  'cartucce-toner': 'per mantenere stampanti e ufficio sempre operativi',
  archiviazione: 'per tenere documenti, pratiche e materiali sotto controllo',
  cancelleria: 'per scrivere, correggere, fissare, tagliare e organizzare',
  'disegno-didattica': 'per scuola, creativita, disegno tecnico e studio',
  'visual-comunicazione': 'per comunicare, esporre e organizzare spazi condivisi',
  'comunita-servizi': 'per ambienti condivisi, pulizia, sicurezza e gestione quotidiana',
  'spedizione-imballaggi': 'per preparare pacchi, documenti e materiali da inviare',
  'informatica-elettronica': 'per postazioni PC, accessori digitali e periferiche',
  'macchine-ufficio': 'per gestire documenti, stampa, taglio, rilegatura e cassa',
  ecosostenibili: 'per scegliere alternative piu attente nei consumi quotidiani',
};
const itemCards = category.items.map((item, index) => ({
  title: item,
  image: imagePool[index % imagePool.length],
  text: `${item} ${itemTone[category.slug] ?? 'per le esigenze quotidiane di scuola, casa e ufficio'}. In negozio puoi verificare formati, modelli e disponibilita.`,
  meta: [
    index % 2 === 0 ? 'Disponibilita da verificare' : 'Scelta guidata',
    index % 3 === 0 ? 'Uso quotidiano' : 'Formati e varianti',
  ],
}));
const title = `${category.label} a Cesena | Buffetti Cucchi`;
const description = `${category.label} Buffetti a Cesena: ${category.summary} Disponibilita, alternative e supporto in negozio.`;
---

<BaseLayout title={title} description={description}>
  <section class="category-hero" style={`--category-accent: ${category.accent ?? '#0000e8'}`}>
    <div class="category-hero__pattern" aria-hidden="true">
      <svg viewBox="0 0 640 420" role="img">
        <path d="M88 80h120v74H88z" />
        <path d="M246 74h76v166h-76z" />
        <path d="M372 94h156v96H372z" />
        <path d="M104 238h170v82H104z" />
        <path d="M344 254h122v90H344z" />
        <circle cx="540" cy="292" r="46" />
        <path d="M118 126h70M262 116h42M390 138h102M126 278h104M366 298h76" />
      </svg>
    </div>

    <div class="container category-hero__inner">
      <div class="category-hero__copy">
        <span class="eyebrow">Catalogo prodotti</span>
        <h1>{category.label}</h1>
        <p>{category.summary}</p>

        <div class="category-hero__actions">
          <a class="btn btn--primary" href={site.phoneHref}>
            <Phone size={18} stroke-width={2.2} class="cta-icon" />
            Chiedi disponibilita
          </a>
          <a class="btn btn--ghost" href="/contatti.html">
            <MapPin size={18} stroke-width={2.2} class="cta-icon" />
            Passa in negozio
          </a>
        </div>
      </div>

      <div class="category-hero__visual">
        <img src={category.image} alt={category.label} />
      </div>
    </div>
  </section>

  <section class="section section--white">
    <div class="container category-detail">
      <div class="section-head">
        <span class="eyebrow">Cosa puoi cercare</span>
        <h2>Sottocategorie e prodotti collegati</h2>
        <p>
          Questa pagina raccoglie la famiglia prodotto in modo piu specifico: puoi usarla
          come promemoria prima di chiamare o passare in negozio.
        </p>
      </div>

      <div class="item-grid">
        {itemCards.map((item, index) => (
          <article>
            <div class="item-card__media">
              <img src={item.image} alt={item.title} loading="lazy" />
              <span>{String(index + 1).padStart(2, '0')}</span>
            </div>
            <div class="item-card__body">
              <strong>{item.title}</strong>
              <p>{item.text}</p>
              <div>
                {item.meta.map((meta) => <em>{meta}</em>)}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section social-cta">
    <div class="container social-cta__inner">
      <div>
        <span class="eyebrow">Negozio reale, risposta reale</span>
        <h2>Vuoi sapere se c'e in negozio?</h2>
        <p>
          Chiama, scrivi o guarda i canali social: per prodotti specifici e disponibilita
          conviene sempre parlare direttamente con Buffetti Cucchi.
        </p>
      </div>

      <div class="social-actions">
        <a href={site.phoneHref}>
          <Phone size={20} stroke-width={2.3} />
          <span>Chiama</span>
        </a>
        <a href={site.facebook} target="_blank" rel="noopener noreferrer">
          <img src="/images/facebook.svg" alt="" loading="lazy" />
          <span>Facebook</span>
        </a>
        <a href={site.instagram} target="_blank" rel="noopener noreferrer">
          <img src="/images/instagram.svg" alt="" loading="lazy" />
          <span>Instagram</span>
        </a>
      </div>
    </div>
  </section>

  <section class="section related-section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Altre famiglie</span>
        <h2>Continua nel catalogo</h2>
      </div>

      <div class="related-grid">
        {relatedCategories.map((item) => (
          <a href={item.href}>
            <img src={item.image} alt={item.label} loading="lazy" />
            <strong>{item.label}</strong>
            <span>{item.summary}</span>
            <ArrowRight size={18} stroke-width={2.2} />
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .eyebrow {
    display: inline-flex;
    margin-bottom: 16px;
    color: var(--category-accent, #0000e8);
    font-size: 0.76rem;
    font-weight: 840;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .category-hero {
    position: relative;
    overflow: hidden;
    padding: 96px 0 82px;
    background:
      radial-gradient(circle at 82% 32%, color-mix(in srgb, var(--category-accent, #0000e8) 18%, transparent), transparent 28%),
      linear-gradient(135deg, rgba(0, 0, 232, 0.08), rgba(0, 166, 232, 0.08)),
      #fff;
  }

  .category-hero__pattern {
    position: absolute;
    inset: auto 0 0 auto;
    width: min(48vw, 620px);
    opacity: 0.12;
    color: var(--category-accent, #0000e8);
    pointer-events: none;
  }

  .category-hero__pattern svg {
    width: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 10;
    stroke-linejoin: round;
    stroke-linecap: round;
  }

  .category-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(320px, 0.72fr);
    gap: 54px;
    align-items: center;
  }

  .category-hero h1,
  .section-head h2,
  .social-cta h2 {
    margin: 0;
    color: var(--color-primary-dark);
    font-size: clamp(2.5rem, 5.2vw, 5rem);
    line-height: 0.94;
    letter-spacing: -0.052em;
  }

  .category-hero p,
  .section-head p,
  .social-cta p {
    max-width: 660px;
    margin: 22px 0 0;
    color: var(--color-muted);
    font-size: 1.06rem;
    line-height: 1.78;
  }

  .category-hero__actions {
    margin-top: 30px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .category-hero__visual {
    min-height: 360px;
    display: grid;
    place-items: center;
    padding: 18px;
    border: 0;
    border-radius: 0;
    background:
      radial-gradient(circle at 50% 52%, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.34) 44%, transparent 68%);
    box-shadow: none;
  }

  .category-hero__visual img {
    width: min(100%, 360px);
    max-height: 290px;
    object-fit: contain;
    filter: drop-shadow(0 28px 36px rgba(0, 31, 69, 0.2));
  }

  .section-head {
    max-width: 760px;
    margin-bottom: 34px;
  }

  .section-head h2,
  .social-cta h2 {
    font-size: clamp(2rem, 4vw, 3.5rem);
  }

  .item-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .item-grid article {
    min-height: 360px;
    overflow: hidden;
    border: 1px solid rgba(204, 221, 237, 0.84);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(255, 255, 255, 0.92)),
      radial-gradient(circle at 88% 10%, color-mix(in srgb, var(--category-accent, #0000e8) 11%, transparent), transparent 36%);
    box-shadow: 0 18px 50px rgba(0, 31, 69, 0.075);
  }

  .item-card__media {
    position: relative;
    height: 160px;
    display: grid;
    place-items: center;
    padding: 20px 20px 34px;
    background:
      radial-gradient(circle at 50% 50%, color-mix(in srgb, var(--category-accent, #0000e8) 12%, transparent), transparent 54%);
  }

  .item-card__media img {
    width: 100%;
    height: 118px;
    object-fit: contain;
    filter: drop-shadow(0 18px 22px rgba(0, 31, 69, 0.1));
  }

  .item-card__media span {
    position: absolute;
    left: 16px;
    bottom: 12px;
    color: var(--category-accent, #0000e8);
    font-weight: 840;
  }

  .item-card__body {
    padding: 22px;
  }

  .item-grid strong {
    display: block;
    color: var(--color-primary-dark);
    font-size: 1.12rem;
    line-height: 1.25;
  }

  .item-grid p {
    margin: 12px 0 0;
    color: var(--color-muted);
    line-height: 1.58;
  }

  .item-card__body div {
    margin-top: 18px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .item-card__body em {
    padding: 6px 9px;
    color: var(--category-accent, #0000e8);
    background: color-mix(in srgb, var(--category-accent, #0000e8) 9%, #fff);
    border-radius: 999px;
    font-size: 0.78rem;
    font-style: normal;
    font-weight: 820;
  }

  .social-cta {
    color: #fff;
    background: #0000e8;
  }

  .social-cta .eyebrow,
  .social-cta h2 {
    color: #fff;
  }

  .social-cta p {
    color: rgba(255, 255, 255, 0.78);
  }

  .social-cta__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 36px;
    align-items: center;
  }

  .social-actions {
    display: grid;
    gap: 12px;
    min-width: 250px;
  }

  .social-actions a {
    min-height: 56px;
    padding: 0 18px;
    display: flex;
    align-items: center;
    gap: 12px;
    color: #0000e8;
    background: #fff;
    border-radius: 4px;
    font-weight: 840;
    transition: transform 0.18s ease;
  }

  .social-actions img {
    width: 20px;
    height: 20px;
  }

  .social-actions a:hover {
    transform: translateY(-3px);
  }

  .related-section {
    background: #f5f8fc;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }

  .related-grid a {
    min-height: 280px;
    padding: 20px;
    display: grid;
    align-content: start;
    gap: 12px;
    border: 1px solid #dfe8f2;
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 16px 42px rgba(0, 31, 69, 0.07);
  }

  .related-grid img {
    width: 100%;
    height: 105px;
    object-fit: contain;
    margin-bottom: 4px;
    filter: drop-shadow(0 14px 18px rgba(0, 31, 69, 0.1));
  }

  .related-grid strong {
    color: #0000e8;
    font-size: 1.05rem;
  }

  .related-grid span {
    color: var(--color-muted);
    line-height: 1.45;
  }

  .related-grid svg {
    margin-top: auto;
    color: #0000e8;
  }

  @media (max-width: 980px) {
    .category-hero__inner,
    .social-cta__inner {
      grid-template-columns: 1fr;
    }

    .related-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .item-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .category-hero {
      padding: 70px 0 58px;
    }

    .category-hero__visual {
      min-height: 260px;
    }

    .item-grid,
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
