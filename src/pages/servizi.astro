---
import BaseLayout from '../layouts/BaseLayout.astro';
import { digitalServices, serviceFamilies } from '../data/catalog';
import { site } from '../data/site';
import { Check, Mail, MapPin, Phone } from '@lucide/astro';
---

<BaseLayout
  title="Servizi Buffetti Cucchi Cesena | PEC, SPID, firma digitale, stampa e spedizioni"
  description="Servizi Buffetti Cucchi a Cesena: PEC, SPID, firma digitale, fotocopie, rilegature, timbri, spedizioni e supporto al banco."
>
  <section class="services-hero">
    <div class="container services-hero__inner">
      <div>
        <span class="eyebrow">Servizi in negozio</span>
        <h1>Pratiche digitali, documenti e spedizioni con una persona davanti.</h1>
        <p>
          Buffetti Group mette al centro PEC, Firma e SPID; Buffetti Cucchi li rende piu vicini:
          passi in negozio, chiedi cosa ti serve e trovi supporto per documenti, stampa, timbri e invii.
        </p>
        <div class="services-hero__actions">
          <a class="btn btn--primary" href={site.phoneHref}>
            <Phone size={18} stroke-width={2.2} class="cta-icon" />
            Chiama il negozio
          </a>
          <a class="btn btn--ghost" href="/contatti.html">
            <MapPin size={18} stroke-width={2.2} class="cta-icon" />
            Dove siamo
          </a>
        </div>
      </div>

      <div class="services-hero__visual">
        <img src="/images/servizi/digital/pec.svg" alt="PEC, Firma e SPID Buffetti Cucchi" />
      </div>
    </div>
  </section>

  <section class="section section--white">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Identita digitale e documenti</span>
        <h2>Servizi da chiedere direttamente al banco</h2>
        <p>
          Le card non sono un catalogo astratto: sono promemoria pratici per capire cosa puoi
          chiedere quando passi in negozio o quando telefoni prima di muoverti.
        </p>
      </div>

      <div class="service-cards">
        {digitalServices.map((service) => (
          <article id={service.href.split('#')[1]}>
            <div class="service-card__media">
              <img src={service.image} alt={service.label} loading="lazy" />
              <span>{service.badge}</span>
            </div>
            <div class="service-card__body">
              <h3>{service.label}</h3>
              <p>{service.detail}</p>
              <ul>
                {service.items.map((item) => (
                  <li>
                    <Check size={17} stroke-width={2.5} />
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section family-section">
    <div class="container family-layout">
      <div class="section-head">
        <span class="eyebrow">Aree servizio</span>
        <h2>Quattro motivi per passare da Cucchi</h2>
      </div>

      <div class="family-grid">
        {serviceFamilies.map((family) => (
          <article>
            <img src={family.image} alt={family.label} loading="lazy" />
            <strong>{family.label}</strong>
            <p>{family.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section service-contact">
    <div class="container service-contact__inner">
      <div>
        <span class="eyebrow">Prima di venire</span>
        <h2>Hai una pratica specifica? Chiedi cosa portare.</h2>
        <p>
          Per servizi digitali, timbri o spedizioni puo essere utile chiamare prima:
          ti aiutano a capire disponibilita, tempi e documenti necessari.
        </p>
      </div>
      <div class="service-contact__actions">
        <a href={site.phoneHref}>
          <Phone size={20} stroke-width={2.3} />
          <span>Telefono</span>
          <strong>{site.phone}</strong>
        </a>
        <a href={site.emailHref}>
          <Mail size={20} stroke-width={2.3} />
          <span>Email</span>
          <strong>{site.email}</strong>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .eyebrow {
    display: inline-flex;
    margin-bottom: 16px;
    color: #0000e8;
    font-size: 0.76rem;
    font-weight: 840;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .services-hero {
    position: relative;
    overflow: hidden;
    padding: 96px 0 84px;
    background: var(--color-primary-dark);
  }

  .services-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(0, 25, 58, 0.94), rgba(0, 38, 80, 0.72) 50%, rgba(0, 31, 69, 0.16)),
      url("/images/hero-servizi.webp") center/cover;
    opacity: 1;
  }

  .services-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.72fr);
    gap: 52px;
    align-items: center;
  }

  .services-hero h1,
  .section-head h2,
  .service-contact h2 {
    margin: 0;
    color: var(--color-primary-dark);
    font-size: clamp(2.45rem, 5vw, 5rem);
    line-height: 0.94;
    letter-spacing: -0.052em;
  }

  .services-hero p,
  .section-head p,
  .service-contact p {
    max-width: 680px;
    margin: 22px 0 0;
    color: var(--color-muted);
    font-size: 1.06rem;
    line-height: 1.78;
  }

  .services-hero .eyebrow,
  .services-hero h1 {
    color: #fff;
  }

  .services-hero p {
    color: rgba(255, 255, 255, 0.82);
  }

  .services-hero__actions {
    margin-top: 30px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .services-hero__visual {
    min-height: 360px;
    display: grid;
    place-items: center;
    padding: 22px;
    border: 0;
    border-radius: 0;
    background:
      radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.88), rgba(255, 255, 255, 0.3) 44%, transparent 68%);
    box-shadow: none;
  }

  .services-hero__visual img {
    width: min(100%, 390px);
    object-fit: contain;
    filter: drop-shadow(0 28px 38px rgba(0, 0, 0, 0.25));
  }

  .section-head {
    max-width: 820px;
    margin-bottom: 36px;
  }

  .section-head h2,
  .service-contact h2 {
    font-size: clamp(2rem, 4vw, 3.55rem);
  }

  .service-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .service-cards article {
    overflow: hidden;
    border: 1px solid rgba(204, 221, 237, 0.84);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(255, 255, 255, 0.92)),
      radial-gradient(circle at 86% 10%, rgba(0, 166, 232, 0.12), transparent 36%);
    box-shadow: 0 18px 52px rgba(0, 31, 69, 0.08);
  }

  .service-card__media {
    position: relative;
    height: 190px;
    display: grid;
    place-items: center;
    padding: 20px 20px 34px;
    background: radial-gradient(circle at 50% 50%, rgba(0, 166, 232, 0.12), transparent 54%);
  }

  .service-card__media img {
    width: 100%;
    height: 145px;
    object-fit: contain;
    filter: drop-shadow(0 18px 22px rgba(0, 31, 69, 0.1));
  }

  .service-card__media span {
    position: absolute;
    left: 16px;
    bottom: 14px;
    padding: 7px 10px;
    color: #0000e8;
    background: rgba(255, 255, 255, 0.86);
    border-radius: 999px;
    font-size: 0.76rem;
    font-weight: 840;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .service-card__body {
    padding: 24px;
  }

  .service-card__body h3 {
    margin: 0;
    color: var(--color-primary-dark);
    font-size: 1.35rem;
    line-height: 1.08;
  }

  .service-card__body p {
    margin: 14px 0 0;
    color: var(--color-muted);
    line-height: 1.65;
  }

  .service-card__body ul {
    margin: 22px 0 0;
    padding: 0;
    display: grid;
    gap: 10px;
    list-style: none;
  }

  .service-card__body li {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    color: var(--color-text);
    font-weight: 760;
    line-height: 1.35;
  }

  .service-card__body svg {
    color: #00a6e8;
    flex: 0 0 auto;
    margin-top: 2px;
  }

  .family-section {
    background: #f5f8fc;
  }

  .family-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.55fr) minmax(0, 1fr);
    gap: 40px;
    align-items: start;
  }

  .family-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .family-grid article {
    min-height: 240px;
    padding: 22px;
    border: 1px solid #dfe8f2;
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 14px 38px rgba(0, 31, 69, 0.06);
  }

  .family-grid img {
    width: 100%;
    height: 92px;
    object-fit: contain;
    margin-bottom: 18px;
    filter: drop-shadow(0 14px 18px rgba(0, 31, 69, 0.1));
  }

  .family-grid strong {
    display: block;
    color: #0000e8;
    font-size: 1.12rem;
  }

  .family-grid p {
    margin: 12px 0 0;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .service-contact {
    color: #fff;
    background: #0000e8;
  }

  .service-contact .eyebrow,
  .service-contact h2 {
    color: #fff;
  }

  .service-contact p {
    color: rgba(255, 255, 255, 0.78);
  }

  .service-contact__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.48fr);
    gap: 40px;
    align-items: center;
  }

  .service-contact__actions {
    display: grid;
    gap: 12px;
  }

  .service-contact__actions a {
    min-height: 78px;
    padding: 16px;
    display: grid;
    grid-template-columns: 30px 1fr;
    gap: 2px 12px;
    align-items: center;
    color: #0000e8;
    background: #fff;
    border-radius: 4px;
  }

  .service-contact__actions svg {
    grid-row: span 2;
  }

  .service-contact__actions span {
    color: var(--color-muted);
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .service-contact__actions strong {
    color: var(--color-primary-dark);
    line-height: 1.2;
  }

  @media (max-width: 980px) {
    .services-hero__inner,
    .family-layout,
    .service-contact__inner {
      grid-template-columns: 1fr;
    }

    .service-cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .services-hero {
      padding: 58px 0 46px;
    }

    .services-hero h1 {
      font-size: clamp(2.2rem, 14vw, 3.35rem);
      line-height: 0.96;
    }

    .services-hero p,
    .section-head p,
    .service-contact p {
      font-size: 1rem;
      line-height: 1.65;
    }

    .services-hero__visual {
      min-height: 190px;
      padding: 12px;
    }

    .services-hero__visual img {
      max-height: 180px;
    }

    .service-cards,
    .family-grid {
      grid-template-columns: 1fr;
    }

    .service-card__media {
      height: 150px;
    }

    .service-card__media img {
      height: 112px;
    }

    .service-contact__actions a {
      grid-template-columns: 26px 1fr;
    }
  }
</style>
