---
import BaseLayout from '../layouts/BaseLayout.astro';
import { digitalServices, productCategories, shopFocusAreas } from '../data/catalog';
import { site } from '../data/site';
import { ArrowRight, MapPin, Phone, Search } from '@lucide/astro';

const heroCategories = productCategories;
const serviceCards = digitalServices.slice(0, 4);
---

<BaseLayout
  title="Buffetti Cucchi Cesena | Cartoleria, ufficio, scuola e servizi digitali"
  description="Buffetti Cucchi a Cesena: prodotti Buffetti, cancelleria, articoli scuola, forniture per ufficio, PEC, firma digitale, fotocopie, spedizioni e servizi in negozio."
>
  <section class="home-hero">
    <div class="home-hero__media">
      <img src="/images/hero-home.png" alt="Esterno della cartoleria Buffetti Cucchi a Cesena" />
    </div>

    <div class="container home-hero__inner">
      <div class="home-hero__content">
        <span class="eyebrow">Buffetti Cucchi Cesena</span>
        <h1>Soluzioni che semplificano scuola, ufficio e pratiche.</h1>
        <p>
          Prodotti Buffetti, servizi digitali, stampa, spedizioni, scuola e ufficio:
          scegli online cosa ti serve e poi parlane con chi lo conosce davvero.
        </p>

        <div class="home-hero__actions">
          <a class="btn btn--primary" href={site.phoneHref}>
            <Phone size={18} stroke-width={2.2} class="cta-icon" />
            Chiama ora
          </a>
          <a class="btn btn--ghost" href={site.mapsUrl} target="_blank" rel="noopener noreferrer">
            <MapPin size={18} stroke-width={2.2} class="cta-icon" />
            Vieni in negozio
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section catalog-section">
    <div class="container catalog-layout">
      <aside class="catalog-sidebar" aria-label="Categorie prodotto">
        {productCategories.map((category, index) => (
          <a class:list={[index === 0 && 'is-active']} href={category.href}>
            <span>{category.label}</span>
            <ArrowRight size={18} stroke-width={2.2} />
          </a>
        ))}
      </aside>

      <div class="catalog-main">
        <div class="section-head">
          <span class="eyebrow">Prodotti</span>
          <h2>Prodotti Buffetti, divisi come li cerchi davvero.</h2>
          <p>
            Ogni categoria apre una pagina propria con prodotti, sottocategorie e immagini:
            niente link finti, niente girotondi, solo percorsi chiari per arrivare al banco preparato.
          </p>
        </div>

        <div class="category-grid">
          {heroCategories.map((category) => (
            <a class="category-card" href={category.href}>
              <span>{category.label}</span>
              <p>{category.summary}</p>
              <ul>
                {category.items.slice(0, 4).map((item) => <li>{item}</li>)}
              </ul>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section departments-section">
    <div class="container business-layout">
      <div class="business-copy">
        <span class="eyebrow">Reparti del negozio</span>
        <h2>Non un portale corporate: un negozio con reparti chiari.</h2>
        <p>
          Scuola, ufficio, servizi al banco e idee regalo restano percorsi autonomi,
          con immagini e contenuti pensati per chi passa fisicamente da Buffetti Cucchi.
        </p>
      </div>

      <div class="business-list">
        {shopFocusAreas.map((area) => (
          <a href={area.href}>
            <img src={area.image} alt="" loading="lazy" />
            <strong>{area.label}</strong>
            <span>{area.text}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section social-section">
    <div class="container social-layout">
      <div class="social-copy">
        <span class="eyebrow">Segui il negozio</span>
        <h2>Novita, vetrine e contatti veloci anche sui social.</h2>
        <p>
          Facebook e Instagram servono davvero: per vedere cosa arriva in negozio,
          chiedere informazioni e restare aggiornato su scuola, cartoleria, servizi e idee regalo.
        </p>
      </div>

      <div class="social-cards">
        <a href={site.facebook} target="_blank" rel="noopener noreferrer">
          <img src="/images/facebook.svg" alt="" loading="lazy" />
          <strong>Facebook</strong>
          <span>Pagina Buffetti Cucchi</span>
        </a>
        <a href={site.instagram} target="_blank" rel="noopener noreferrer">
          <img src="/images/instagram.svg" alt="" loading="lazy" />
          <strong>Instagram</strong>
          <span>Vetrine e novita</span>
        </a>
      </div>
    </div>
  </section>

  <section class="section services-section">
    <div class="container">
      <div class="section-head section-head--center">
        <span class="eyebrow">Servizi digitali e documenti</span>
        <h2>PEC, firma, stampa e spedizioni senza rimbalzare tra mille sportelli.</h2>
      </div>

      <div class="service-grid">
        {serviceCards.map((service) => (
          <a class="service-card" href={service.href}>
            <span>{service.label}</span>
            <p>{service.text}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section visit-section">
    <div class="container visit-layout">
      <div class="visit-copy">
        <span class="eyebrow">Negozio Buffetti a Cesena</span>
        <h2>Vedi, confronti, chiedi. E torni a casa con la cosa giusta.</h2>
        <p>
          Ci trovi in Viale Matteotti, 593, zona Ippodromo. Passa per prodotti Buffetti,
          scuola, ufficio, servizi digitali, fotocopie, timbri, rilegature e spedizioni.
        </p>

        <div class="visit-facts">
          <div>
            <span>Telefono</span>
            <strong>{site.phone}</strong>
          </div>
          <div>
            <span>Orari</span>
            <strong>Lun-Ven 8:30-12:30 / 15:30-19:00</strong>
          </div>
          <div>
            <span>Indirizzo</span>
            <strong>Viale Matteotti, 593 - Cesena</strong>
          </div>
        </div>
      </div>

      <div class="visit-map">
        <iframe
          src={site.mapsEmbedUrl}
          title="Mappa Buffetti Cucchi Cesena"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  .eyebrow {
    display: inline-flex;
    margin-bottom: 16px;
    color: #0000e8;
    font-size: 0.76rem;
    font-weight: 840;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .home-hero {
    position: relative;
    min-height: 660px;
    display: grid;
    align-items: center;
    overflow: hidden;
    color: #fff;
    background: #001f45;
  }

  .home-hero__media {
    position: absolute;
    inset: 0;
  }

  .home-hero__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(0, 16, 46, 0.94), rgba(0, 18, 60, 0.72) 48%, rgba(0, 0, 232, 0.16)),
      linear-gradient(0deg, rgba(0, 12, 34, 0.68), transparent 62%);
  }

  .home-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .home-hero__inner {
    position: relative;
    z-index: 1;
    padding: 90px 0 74px;
  }

  .home-hero__content {
    max-width: 760px;
  }

  .home-hero .eyebrow {
    color: #fff;
    padding: 8px 12px;
    background: #0000e8;
    border-radius: 4px;
  }

  .home-hero h1 {
    margin: 0;
    color: #fff;
    font-size: clamp(2.8rem, 5.2vw, 5.3rem);
    line-height: 0.94;
    letter-spacing: -0.05em;
    text-wrap: balance;
  }

  .home-hero p {
    max-width: 650px;
    margin: 24px 0 0;
    color: rgba(255, 255, 255, 0.84);
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .hero-search {
    width: min(100%, 660px);
    height: 58px;
    margin-top: 32px;
    display: grid;
    grid-template-columns: 1fr 58px;
    overflow: hidden;
    border-radius: 999px;
    border: 1.5px solid rgba(255, 255, 255, 0.9);
    background: #fff;
    box-shadow: 0 20px 58px rgba(0, 0, 0, 0.22);
  }

  .hero-search input {
    min-width: 0;
    padding: 0 24px;
    border: 0;
    outline: 0;
    color: var(--color-primary-dark);
  }

  .hero-search button {
    border: 0;
    color: #0000e8;
    background: #fff;
    cursor: pointer;
  }

  .home-hero__actions {
    margin-top: 28px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .catalog-section {
    background: #fff;
  }

  .catalog-layout {
    display: grid;
    grid-template-columns: 270px minmax(0, 1fr);
    gap: 34px;
    align-items: start;
  }

  .catalog-sidebar {
    position: sticky;
    top: 226px;
    display: grid;
    border-right: 1px solid #dce4ef;
  }

  .catalog-sidebar a {
    min-height: 50px;
    padding: 0 14px 0 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    color: #050915;
    font-weight: 780;
    border-bottom: 1px solid #edf2f7;
  }

  .catalog-sidebar a:hover,
  .catalog-sidebar .is-active {
    color: #0000e8;
    background: #eef3ff;
  }

  .section-head {
    max-width: 780px;
    margin-bottom: 34px;
  }

  .section-head--center {
    margin-inline: auto;
    text-align: center;
  }

  .section-head h2,
  .business-copy h2,
  .visit-copy h2 {
    margin: 0;
    color: var(--color-primary-dark);
    font-size: clamp(2.1rem, 4.2vw, 3.75rem);
    line-height: 0.98;
    letter-spacing: -0.048em;
  }

  .section-head p,
  .business-copy p,
  .visit-copy p {
    margin: 20px 0 0;
    color: var(--color-muted);
    font-size: 1.05rem;
    line-height: 1.78;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .category-card,
  .service-card,
  .business-list a {
    border: 1px solid #dfe8f2;
    background: #fff;
    border-radius: 4px;
    box-shadow: 0 16px 44px rgba(0, 31, 69, 0.07);
    transition: transform 0.18s ease, border-color 0.18s ease;
  }

  .category-card:hover,
  .service-card:hover,
  .business-list a:hover {
    transform: translateY(-4px);
    border-color: rgba(0, 0, 232, 0.3);
  }

  .category-card {
    min-height: 252px;
    padding: 24px;
  }

  .category-card span,
  .service-card span {
    display: block;
    color: #0000e8;
    font-size: 1.18rem;
    font-weight: 860;
    line-height: 1.12;
  }

  .category-card p,
  .service-card p {
    margin: 12px 0 0;
    color: var(--color-muted);
    line-height: 1.58;
  }

  .category-card ul {
    margin: 20px 0 0;
    padding: 0;
    display: grid;
    gap: 8px;
    list-style: none;
  }

  .category-card li {
    position: relative;
    padding-left: 16px;
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 720;
  }

  .category-card li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.58em;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: #00a6e8;
  }

  .departments-section {
    background: #f5f8fc;
  }

  .business-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 50px;
    align-items: center;
  }

  .business-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .business-list a {
    min-height: 164px;
    padding: 20px;
  }

  .business-list img {
    width: 100%;
    height: 72px;
    object-fit: contain;
    margin-bottom: 14px;
  }

  .business-list strong,
  .business-list span {
    display: block;
  }

  .business-list strong {
    color: var(--color-primary-dark);
    font-size: 1.04rem;
  }

  .social-section {
    background:
      linear-gradient(135deg, rgba(0, 0, 232, 0.08), rgba(0, 166, 232, 0.08)),
      #fff;
  }

  .social-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 0.72fr);
    gap: 42px;
    align-items: center;
  }

  .social-copy h2 {
    margin: 0;
    color: var(--color-primary-dark);
    font-size: clamp(2.1rem, 4.2vw, 3.75rem);
    line-height: 0.98;
    letter-spacing: -0.048em;
  }

  .social-copy p {
    margin: 20px 0 0;
    color: var(--color-muted);
    font-size: 1.05rem;
    line-height: 1.78;
  }

  .social-cards {
    display: grid;
    gap: 14px;
  }

  .social-cards a {
    min-height: 108px;
    padding: 22px;
    display: grid;
    grid-template-columns: 46px 1fr;
    align-items: center;
    gap: 4px 14px;
    border: 1px solid #dfe8f2;
    border-radius: 4px;
    background: #fff;
    box-shadow: 0 16px 44px rgba(0, 31, 69, 0.08);
    transition: transform 0.18s ease;
  }

  .social-cards a:hover {
    transform: translateY(-4px);
  }

  .social-cards img {
    width: 26px;
    height: 26px;
    grid-row: span 2;
  }

  .social-cards strong {
    color: var(--color-primary-dark);
    font-size: 1.08rem;
  }

  .social-cards span {
    color: var(--color-muted);
  }

  .business-list span {
    margin-top: 7px;
    color: var(--color-muted);
    line-height: 1.45;
  }

  .services-section {
    color: #fff;
    background: #0000e8;
  }

  .services-section .eyebrow,
  .services-section h2 {
    color: #fff;
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }

  .service-card {
    min-height: 190px;
    padding: 24px;
    background: rgba(255, 255, 255, 0.98);
  }

  .visit-section {
    background: #fff;
  }

  .visit-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(0, 1.12fr);
    gap: 42px;
    align-items: center;
  }

  .visit-facts {
    margin-top: 28px;
    display: grid;
    gap: 12px;
  }

  .visit-facts div {
    padding: 16px 18px;
    border: 1px solid #dfe8f2;
    border-radius: 4px;
    background: #f8fbff;
  }

  .visit-facts span,
  .visit-facts strong {
    display: block;
  }

  .visit-facts span {
    color: #0000e8;
    font-size: 0.74rem;
    font-weight: 860;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .visit-facts strong {
    margin-top: 4px;
    color: var(--color-primary-dark);
    line-height: 1.35;
  }

  .visit-map {
    min-height: 440px;
    overflow: hidden;
    border: 1px solid #dfe8f2;
    border-radius: 4px;
    box-shadow: 0 22px 70px rgba(0, 31, 69, 0.12);
  }

  .visit-map iframe {
    width: 100%;
    height: 100%;
    min-height: 440px;
    display: block;
    border: 0;
  }

  @media (max-width: 1080px) {
    .category-grid,
    .service-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .catalog-layout {
      grid-template-columns: 1fr;
    }

    .catalog-sidebar {
      position: static;
      display: flex;
      overflow-x: auto;
      border-right: 0;
      scrollbar-width: none;
    }

    .catalog-sidebar::-webkit-scrollbar {
      display: none;
    }

    .catalog-sidebar a {
      flex: 0 0 auto;
      border: 1px solid #dfe8f2;
      border-radius: 4px;
      margin-right: 8px;
    }
  }

  @media (max-width: 860px) {
    .business-layout,
    .social-layout,
    .visit-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .home-hero {
      min-height: auto;
    }

    .home-hero__inner {
      padding: 64px 0 46px;
    }

    .home-hero h1 {
      font-size: clamp(2.35rem, 15vw, 3.45rem);
      line-height: 0.96;
    }

    .home-hero p,
    .section-head p,
    .business-copy p,
    .visit-copy p {
      font-size: 1rem;
      line-height: 1.68;
    }

    .category-grid,
    .service-grid,
    .business-list {
      grid-template-columns: 1fr;
    }

    .hero-search {
      height: 52px;
      grid-template-columns: 1fr 52px;
    }

    .catalog-sidebar {
      margin-inline: -12px;
      padding-inline: 12px;
    }

    .category-card,
    .service-card,
    .business-list a {
      min-height: auto;
      padding: 20px;
    }

    .social-cards,
    .visit-facts {
      grid-template-columns: 1fr;
    }

    .visit-map,
    .visit-map iframe {
      min-height: 320px;
    }
  }
</style>
