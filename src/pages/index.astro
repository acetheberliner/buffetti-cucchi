---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
import { Phone, MapPin } from '@lucide/astro';
---

<BaseLayout
  title="Buffetti Cucchi Cesena | Cartoleria, ufficio e servizi digitali"
  description="Buffetti Cucchi a Cesena: cancelleria, articoli per scuola e ufficio, servizi digitali, fotocopie, spedizioni e forniture per aziende."
>
  <section class="hero">
	<div class="hero__media">
		<img src="/images/hero-home.webp" alt="Esterno della cartoleria Buffetti Cucchi a Cesena" />
	</div>

	<div class="container hero__inner">
		<div class="hero__content">

		<h1>Scuola, ufficio e pratiche: ci pensiamo noi</h1>

		<p>
			Cancelleria, forniture per aziende, fotocopie, spedizioni, PEC e firma digitale tutto in un unico punto, con assistenza diretta in negozio.
		</p>

		<div class="hero__actions">
			<a class="btn btn--light" href="tel:+390547334488">
				<Phone size={18} stroke-width={2.2} class="cta-icon" />
				Chiama ora
			</a>
			<a class="btn btn--light" href="/contatti.html">
				<MapPin size={18} stroke-width={2.2} class="cta-icon" />
				Come arrivare
			</a>
		</div>
		</div>
	</div>

	<div class="container hero__dock-wrap">
		<div class="hero__dock" aria-label="Servizi principali">
		<a href="/articoli-per-la-scuola.html">
			<span>Scuola</span>
			<strong>Zaini, quaderni, astucci e materiale scolastico</strong>
		</a>

		<a href="/articoli-per-l-ufficio.html">
			<span>Ufficio</span>
			<strong>Carta, toner, cartucce e forniture professionali</strong>
		</a>

		<a href="/servizi.html">
			<span>Servizi</span>
			<strong>PEC, firma digitale, fotocopie e spedizioni</strong>
		</a>

		<a href="/contatti.html">
			<span>Sede</span>
			<strong>Viale Matteotti, 593 · Cesena</strong>
		</a>
		</div>
	</div>
  </section>

  <section class="section section--white">
    <div class="container split">
      <div class="split__content">
        <span class="eyebrow">Per privati e aziende</span>
        <h2>Un punto unico per acquisti, documenti e servizi</h2>
        <p>
          Che tu debba acquistare materiale scolastico, ordinare prodotti per l’ufficio,
          stampare documenti o richiedere servizi digitali, trovi assistenza diretta in negozio.
        </p>

        <ul>
          <li>Cancelleria e prodotti Buffetti</li>
          <li>Servizi di stampa, fotocopia e rilegatura</li>
          <li>Spedizioni e ritiro merce con corrieri convenzionati</li>
          <li>Forniture per uffici, studi professionali e aziende</li>
        </ul>

        <a class="btn btn--primary" href="/servizi.html">Vedi tutti i servizi</a>
      </div>

      <div class="split__image">
        <img src="/images/hero-servizi.webp" alt="Servizi di fotocopia e stampa documenti" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="section location-section">
  <div class="container location">
    <div class="location__content">
      <span class="eyebrow">Dove siamo</span>

      <h2>Passa in negozio a Cesena</h2>

      <p>
        Ci trovi in Viale Matteotti, 593, in zona Ippodromo. Puoi raggiungerci facilmente
        per acquistare prodotti, richiedere servizi o ritirare forniture per il tuo ufficio.
      </p>

      <div class="location__info">
        <div>
          <span>Indirizzo</span>
          <strong>Viale Matteotti, 593 · Cesena (FC)</strong>
        </div>

        <div>
          <span>Telefono</span>
          <strong>{site.phone}</strong>
        </div>

        <div>
          <span>Orari</span>
          <strong>Dal lunedì al venerdì <br/>08:30 - 12:30<br/>15:30 - 19:00</strong>
        </div>
      </div>

      <div class="location__actions">
        <a class="btn btn--primary" href={site.mapsUrl} target="_blank" rel="noopener noreferrer">
          <MapPin size={18} stroke-width={2.2} class="cta-icon" />
          Apri Google Maps
        </a>

        <a class="btn btn--ghost" href={site.phoneHref}>
          <Phone size={18} stroke-width={2.2} class="cta-icon" />
          Chiama il negozio
        </a>
      </div>
    </div>

    <div class="location__map" aria-label="Mappa Buffetti Cucchi Cesena">
      <iframe
        src={site.mapsEmbedUrl}
        title="Mappa Buffetti Cucchi Cesena"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</section>
</BaseLayout>

<style>
  .hero {
  position: relative;
  min-height: 680px;
  display: grid;
  align-items: center;
  overflow: visible;
  color: #fff;
  background: var(--color-primary-dark);
}

.hero__media {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.hero__media::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 1;
  background:
    linear-gradient(90deg, rgba(0, 24, 56, 0.92) 0%, rgba(0, 31, 69, 0.76) 42%, rgba(0, 31, 69, 0.24) 78%),
    linear-gradient(0deg, rgba(0, 24, 56, 0.74) 0%, rgba(0, 24, 56, 0.12) 55%);
}

.hero__media::after {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 2;
  background:
    radial-gradient(circle at 18% 42%, rgba(0, 166, 232, 0.2), transparent 30%),
    radial-gradient(circle at 78% 18%, rgba(255, 255, 255, 0.08), transparent 22%);
  pointer-events: none;
}

.hero__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero__inner {
  position: relative;
  z-index: 3;
  padding: 120px 0 150px;
}

.hero__content {
  max-width: 690px;
}

.hero__eyebrow {
  display: inline-flex;
  margin-bottom: 22px;
  padding: 9px 14px;
  border-radius: 999px;
  color: #dff5ff;
  background: rgba(0, 166, 232, 0.18);
  border: 1px solid rgba(255, 255, 255, 0.18);
  font-size: 0.78rem;
  font-weight: var(--weight-bold);
  text-transform: uppercase;
  letter-spacing: 0.11em;
}

.hero h1 {
  max-width: 680px;
  margin: 0;
  color: #fff;
  font-size: clamp(2.9rem, 5.4vw, 5.15rem);
  line-height: 0.96;
  letter-spacing: -0.052em;
  text-wrap: balance;
  text-shadow: 0 18px 60px rgba(0, 0, 0, 0.28);
}

.hero p {
  max-width: 590px;
  margin: 24px 0 0;
  color: rgba(255, 255, 255, 0.84);
  font-size: clamp(1rem, 1.25vw, 1.13rem);
  line-height: 1.75;
}

.hero__actions {
  margin-top: 34px;
  display: flex;
  gap: 13px;
  flex-wrap: wrap;
}

.btn--light {
  color: var(--color-primary-dark);
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(255, 255, 255, 0.38);
  box-shadow: 0 14px 30px rgba(0, 0, 0, 0.12);
}

.hero__dock-wrap {
  position: absolute;
  left: 50%;
  bottom: 0;
  z-index: 4;
  transform: translate(-50%, 50%);
}

.hero__dock {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  overflow: hidden;
  border-radius: 26px;
  background: rgba(255, 255, 255, 0.96);
  border: 1px solid rgba(0, 59, 122, 0.12);
  box-shadow: 0 24px 70px rgba(0, 31, 69, 0.2);
}

.hero__dock a {
  min-height: 116px;
  padding: 24px;
  display: grid;
  align-content: center;
  gap: 8px;
  border-right: 1px solid rgba(0, 59, 122, 0.1);
  transition: background 0.2s ease, transform 0.2s ease;
}

.hero__dock a:last-child {
  border-right: 0;
}

.hero__dock a:hover {
  background: rgba(0, 166, 232, 0.08);
}

.hero__dock span {
  color: var(--color-accent);
  font-size: 0.76rem;
  font-weight: var(--weight-heavy);
  text-transform: uppercase;
  letter-spacing: 0.09em;
}

.hero__dock strong {
  color: var(--color-primary-dark);
  font-size: 0.98rem;
  line-height: 1.45;
  font-weight: var(--weight-semibold);
  letter-spacing: -0.02em;
}

.hero + .section {
  padding-top: 142px;
}

@media (max-width: 980px) {
  .hero {
    min-height: 650px;
  }

  .hero__inner {
    padding: 110px 0 140px;
  }

  .hero__dock {
    grid-template-columns: repeat(2, 1fr);
  }

  .hero__dock a {
    min-height: 104px;
  }

  .hero__dock a:nth-child(2) {
    border-right: 0;
  }

  .hero__dock a:nth-child(1),
  .hero__dock a:nth-child(2) {
    border-bottom: 1px solid rgba(0, 59, 122, 0.1);
  }
}

@media (max-width: 680px) {
  .hero {
    min-height: auto;
    overflow: hidden;
  }

  .hero__inner {
    padding: 92px 0 34px;
  }

  .hero h1 {
    font-size: clamp(2.45rem, 12vw, 3.7rem);
  }

  .hero p {
    max-width: 100%;
  }

  .hero__dock-wrap {
    position: relative;
    left: auto;
    bottom: auto;
    transform: none;
    margin-top: -8px;
    padding-bottom: 28px;
  }

  .hero__dock {
    grid-template-columns: 1fr;
    border-radius: 22px;
  }

  .hero__dock a {
    min-height: auto;
    padding: 18px;
    border-right: 0;
    border-bottom: 1px solid rgba(0, 59, 122, 0.1);
  }

  .hero__dock a:last-child {
    border-bottom: 0;
  }

  .hero + .section {
    padding-top: 64px;
  }
}

  .intro {
    max-width: 880px;
    text-align: center;
  }

  .intro h2,
  .section-head h2,
  .split h2 {
    margin: 0;
    color: var(--color-primary-dark);
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1;
    letter-spacing: -0.045em;
  }

  .intro p {
    margin: 22px auto 0;
    color: var(--color-muted);
    font-size: 1.06rem;
    line-height: 1.8;
  }

  .section-head {
    max-width: 760px;
    margin-bottom: 30px;
  }

  .categories {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }

  .categories article {
    position: relative;
    overflow: hidden;
    padding: 30px;
    min-height: 245px;
    border-radius: var(--radius-md);
    background: #fff;
    box-shadow: var(--shadow-card);
    border: 1px solid var(--color-border);
  }

  .categories article::after {
    content: "";
    position: absolute;
    right: -40px;
    bottom: -40px;
    width: 140px;
    height: 140px;
    border-radius: 999px;
    background: rgba(0, 166, 232, 0.12);
  }

  .categories span {
    display: inline-flex;
    margin-bottom: 34px;
    color: var(--color-accent);
    font-weight: var(--weight-heavy);
  }

  .categories h3 {
    margin: 0;
    color: var(--color-primary);
    font-size: 1.45rem;
    letter-spacing: -0.025em;
  }

  .categories p {
    margin: 14px 0 22px;
    color: var(--color-muted);
    line-height: 1.7;
  }

  .categories a {
    color: var(--color-primary);
    font-weight: var(--weight-bold);
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 42px;
    align-items: center;
  }

  .split__content p {
    color: var(--color-muted);
    line-height: 1.8;
    font-size: 1.04rem;
  }

  .split__content ul {
    margin: 26px 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 12px;
  }

  .split__content li {
    position: relative;
    padding-left: 28px;
    color: var(--color-text);
    font-weight: var(--weight-semibold);
  }

  .split__content li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--color-accent);
    font-weight: var(--weight-heavy);
  }

  .split__image {
    overflow: hidden;
    border-radius: 34px;
    box-shadow: var(--shadow-soft);
    min-height: 440px;
    background: #dce8f5;
  }

  .split__image img {
    width: 100%;
    height: 100%;
    min-height: 440px;
    object-fit: cover;
  }

  .location-section {
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 18% 18%, rgba(0, 166, 232, 0.12), transparent 28%),
    linear-gradient(180deg, #f6f8fb 0%, #ffffff 100%);
}

.location {
  display: grid;
  grid-template-columns: minmax(0, 0.88fr) minmax(0, 1.12fr);
  gap: 42px;
  align-items: center;
}

.location__content {
  max-width: 560px;
}

.location__content h2 {
  margin: 0;
  color: var(--color-primary-dark);
  font-size: clamp(2.2rem, 4.4vw, 4rem);
  line-height: 0.96;
  letter-spacing: -0.045em;
}

.location__content p {
  margin: 22px 0 0;
  color: var(--color-muted);
  font-size: 1.05rem;
  line-height: 1.8;
}

.location__info {
  margin: 28px 0 0;
  display: grid;
  gap: 12px;
}

.location__info div {
  padding: 15px 17px;
  border-radius: 18px;
  background: #fff;
  border: 1px solid rgba(0, 59, 122, 0.1);
  box-shadow: 0 12px 30px rgba(0, 31, 69, 0.06);
}

.location__info span,
.location__info strong {
  display: block;
}

.location__info span {
  color: var(--color-accent);
  font-size: 0.72rem;
  font-weight: var(--weight-heavy);
  text-transform: uppercase;
  letter-spacing: 0.09em;
}

.location__info strong {
  margin-top: 4px;
  color: var(--color-primary-dark);
  font-size: 0.96rem;
  font-weight: var(--weight-semibold);
  line-height: 1.45;
}

.location__actions {
  margin-top: 28px;
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.location__map {
  position: relative;
  overflow: hidden;
  min-height: 430px;
  border-radius: 34px;
  background: #dce8f5;
  border: 1px solid rgba(0, 59, 122, 0.12);
  box-shadow: var(--shadow-soft);
}

.location__map::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.16), transparent 34%),
    radial-gradient(circle at 12% 18%, rgba(0, 166, 232, 0.16), transparent 28%);
}

.location__map iframe {
  width: 100%;
  height: 100%;
  min-height: 430px;
  display: block;
  border: 0;
  filter: saturate(0.9) contrast(0.95);
}

  @media (max-width: 980px) {
    .hero {
      min-height: auto;
      padding-top: 96px;
    }

    .hero__inner {
      grid-template-columns: 1fr;
      gap: 34px;
      padding-bottom: 34px;
    }

    .hero__cards {
      grid-template-columns: repeat(3, 1fr);
    }

    .hero__strip,
    .categories,
    .split {
      grid-template-columns: 1fr;
    }

    .hero__strip {
      border-radius: 24px 24px 0 0;
    }

    .hero__strip div {
      border-right: 0;
      border-bottom: 1px solid rgba(0, 59, 122, 0.1);
    }

    .hero__strip div:last-child {
      border-bottom: 0;
    }
  }

  @media (max-width: 680px) {
    .hero {
      padding-top: 72px;
    }

    .hero h1 {
      font-size: clamp(2.8rem, 15vw, 4.4rem);
    }

    .hero p {
      font-size: 1rem;
    }

    .hero__cards {
      grid-template-columns: 1fr;
    }

    .split__image,
    .split__image img {
      min-height: 300px;
    }
  }

  .cta-icon {
    margin-right: 5px;
  }
</style>