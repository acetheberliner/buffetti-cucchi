---
import BaseLayout from '../layouts/BaseLayout.astro';
import { digitalServices, shopFocusAreas } from '../data/catalog';
import { site } from '../data/site';
import { Mail, MapPin, Phone } from '@lucide/astro';
---

<BaseLayout
  title="Contatti Buffetti Cucchi Cesena | Telefono, email, social e indicazioni"
  description="Contatta Buffetti Cucchi a Cesena: telefono, email, Facebook, Instagram, indirizzo, orari e indicazioni per raggiungere il negozio."
>
  <section class="contact-hero">
    <div class="container contact-hero__inner">
      <div>
        <span class="eyebrow">Contatti</span>
        <h1>Hai bisogno di aiuto o vuoi sapere se un prodotto c'e?</h1>
        <p>
          Chiama, scrivi una email, guarda i social o passa in Viale Matteotti.
          Per prodotti e servizi specifici conviene chiedere prima: risparmi tempo e arrivi gia orientato.
        </p>

        <div class="contact-hero__actions">
          <a class="btn btn--primary" href={site.phoneHref}>
            <Phone size={18} stroke-width={2.2} class="cta-icon" />
            Chiama ora
          </a>
          <a class="btn btn--ghost" href={site.mapsUrl} target="_blank" rel="noopener noreferrer">
            <MapPin size={18} stroke-width={2.2} class="cta-icon" />
            Apri Google Maps
          </a>
        </div>
      </div>

      <div class="contact-panel">
        <span>Buffetti Cucchi s.a.s.</span>
        <a href={site.phoneHref}>
          <Phone size={20} stroke-width={2.3} />
          <strong>{site.phone}</strong>
        </a>
        <a href={site.emailHref}>
          <Mail size={20} stroke-width={2.3} />
          <strong>{site.email}</strong>
        </a>
        <a href={site.mapsUrl} target="_blank" rel="noopener noreferrer">
          <MapPin size={20} stroke-width={2.3} />
          <strong>Viale Matteotti, 593 - Cesena</strong>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--white">
    <div class="container contact-actions">
      <a href={site.facebook} target="_blank" rel="noopener noreferrer">
        <img src="/images/facebook.svg" alt="" loading="lazy" />
        <strong>Facebook</strong>
        <span>Pagina del negozio</span>
      </a>
      <a href={site.instagram} target="_blank" rel="noopener noreferrer">
        <img src="/images/instagram.svg" alt="" loading="lazy" />
        <strong>Instagram</strong>
        <span>Vetrine, novita e idee</span>
      </a>
      <a href={site.emailHref}>
        <Mail size={26} stroke-width={2.2} />
        <strong>Email</strong>
        <span>Richieste e informazioni</span>
      </a>
    </div>
  </section>

  <section class="section contact-map-section">
    <div class="container map-layout">
      <div class="map-copy">
        <span class="eyebrow">Dove siamo</span>
        <h2>Passa in negozio a Cesena, zona Ippodromo.</h2>
        <p>
          Puoi raggiungere Buffetti Cucchi per acquistare prodotti, chiedere servizi digitali,
          stampare documenti, ritirare forniture o scegliere articoli per scuola e ufficio.
        </p>

        <div class="hours">
          <p><strong>Lunedi - Venerdi</strong><span>8:30 - 12:30 / 15:30 - 19:00</span></p>
          <p><strong>Sabato</strong><span>09:00 - 12:30</span></p>
          <p><strong>Domenica</strong><span>Chiuso</span></p>
        </div>
      </div>

      <div class="map-frame">
        <iframe
          src={site.mapsEmbedUrl}
          title="Mappa Buffetti Cucchi Cesena"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <section class="section section--white">
    <div class="container ask-layout">
      <div class="section-head">
        <span class="eyebrow">Cosa puoi chiedere</span>
        <h2>Prodotti, servizi e supporto pratico</h2>
      </div>

      <div class="ask-grid">
        {shopFocusAreas.map((area) => (
          <article>
            <img src={area.image} alt="" loading="lazy" />
            <strong>{area.label}</strong>
            <p>{area.text}</p>
          </article>
        ))}
        {digitalServices.slice(0, 2).map((service) => (
          <article>
            <img src={service.image} alt="" loading="lazy" />
            <strong>{service.label}</strong>
            <p>{service.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .eyebrow {
    display: inline-flex;
    margin-bottom: 16px;
    color: #0000e8;
    font-size: 0.76rem;
    font-weight: 840;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .contact-hero {
    position: relative;
    overflow: hidden;
    padding: 96px 0 84px;
    color: #fff;
    background: var(--color-primary-dark);
  }

  .contact-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(0, 25, 58, 0.94), rgba(0, 38, 80, 0.72) 52%, rgba(0, 31, 69, 0.2)),
      url("/images/hero-contatti.webp") center/cover;
  }

  .contact-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 0.52fr);
    gap: 48px;
    align-items: center;
  }

  .contact-hero h1,
  .map-copy h2,
  .section-head h2 {
    margin: 0;
    color: var(--color-primary-dark);
    font-size: clamp(2.45rem, 5vw, 5rem);
    line-height: 0.94;
    letter-spacing: -0.052em;
  }

  .contact-hero p,
  .map-copy p {
    max-width: 680px;
    margin: 22px 0 0;
    color: var(--color-muted);
    font-size: 1.06rem;
    line-height: 1.78;
  }

  .contact-hero .eyebrow,
  .contact-hero h1 {
    color: #fff;
  }

  .contact-hero p {
    color: rgba(255, 255, 255, 0.82);
  }

  .contact-hero__actions {
    margin-top: 30px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .contact-panel {
    padding: 28px;
    border: 1px solid #dfe8f2;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.18);
  }

  .contact-panel > span {
    display: block;
    margin-bottom: 20px;
    color: #0000e8;
    font-weight: 840;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .contact-panel a {
    min-height: 54px;
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--color-primary-dark);
    border-top: 1px solid #eef2f7;
  }

  .contact-panel a:first-of-type {
    border-top: 0;
  }

  .contact-panel svg {
    color: #0000e8;
    flex: 0 0 auto;
  }

  .contact-actions {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .contact-actions a {
    min-height: 120px;
    padding: 22px;
    display: grid;
    grid-template-columns: 36px 1fr;
    align-items: center;
    gap: 4px 14px;
    border: 1px solid #dfe8f2;
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 16px 44px rgba(0, 31, 69, 0.08);
  }

  .contact-actions img,
  .contact-actions svg {
    width: 26px;
    height: 26px;
    grid-row: span 2;
    color: #0000e8;
  }

  .contact-actions strong {
    color: var(--color-primary-dark);
    font-size: 1.1rem;
  }

  .contact-actions span {
    color: var(--color-muted);
  }

  .contact-map-section {
    background: #f5f8fc;
  }

  .map-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
    gap: 42px;
    align-items: center;
  }

  .map-copy h2,
  .section-head h2 {
    font-size: clamp(2rem, 4vw, 3.55rem);
  }

  .hours {
    margin-top: 28px;
    display: grid;
    gap: 10px;
  }

  .hours p {
    margin: 0;
    padding: 16px;
    border: 1px solid #dfe8f2;
    border-radius: 8px;
    background: #fff;
  }

  .hours strong,
  .hours span {
    display: block;
  }

  .hours strong {
    color: #0000e8;
  }

  .hours span {
    margin-top: 3px;
    color: var(--color-muted);
  }

  .map-frame {
    min-height: 460px;
    overflow: hidden;
    border: 1px solid #dfe8f2;
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 24px 70px rgba(0, 31, 69, 0.12);
  }

  .map-frame iframe {
    width: 100%;
    height: 100%;
    min-height: 460px;
    display: block;
    border: 0;
  }

  .ask-layout {
    display: grid;
    grid-template-columns: minmax(260px, 0.44fr) minmax(0, 1fr);
    gap: 36px;
    align-items: start;
  }

  .ask-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .ask-grid article {
    min-height: 220px;
    padding: 22px;
    border: 1px solid #dfe8f2;
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 14px 38px rgba(0, 31, 69, 0.06);
  }

  .ask-grid img {
    width: 100%;
    height: 82px;
    object-fit: contain;
    margin-bottom: 16px;
    filter: drop-shadow(0 14px 18px rgba(0, 31, 69, 0.1));
  }

  .ask-grid strong {
    display: block;
    color: #0000e8;
    font-size: 1.08rem;
  }

  .ask-grid p {
    margin: 10px 0 0;
    color: var(--color-muted);
    line-height: 1.55;
  }

  @media (max-width: 980px) {
    .contact-hero__inner,
    .map-layout,
    .ask-layout {
      grid-template-columns: 1fr;
    }

    .contact-actions,
    .ask-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .contact-hero {
      padding: 70px 0 58px;
    }

    .contact-actions,
    .ask-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
