---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
import { productCategories } from '../data/catalog';
import BrandShowcase from './BrandShowcase.astro';
import ProductShowcase from './ProductShowcase.astro';

import {
  Archive,
  Armchair,
  ArrowRight,
  BadgeCheck,
  BookOpen,
  Box,
  Briefcase,
  Check,
  Copy,
  FileText,
  Gift,
  Lightbulb,
  Package,
  PenLine,
  Printer,
  Ruler,
  Scissors,
  ShieldCheck,
  Phone,
  Stamp,
  Truck,
  Wallet,
} from '@lucide/astro';

const { page } = Astro.props;

const groups = page.productGroups ?? page.cards ?? [];
const relatedCategories = productCategories.filter((category) =>
  page.catalogSlugs?.includes(category.slug)
);
const heroVisual =
  page.heroVisual ?? page.showcase?.items?.[0]?.image ?? page.focusImage ?? page.heroImage;
const categoryBySlug = new Map(productCategories.map((category) => [category.slug, category]));

const icons = {
  archive: Archive,
  book: BookOpen,
  box: Box,
  chair: Armchair,
  copy: Copy,
  desk: Lightbulb,
  digital: ShieldCheck,
  gift: Gift,
  machines: Package,
  office: Briefcase,
  paper: FileText,
  pen: PenLine,
  printer: Printer,
  ruler: Ruler,
  school: BookOpen,
  shipping: Truck,
  stamp: Stamp,
  tools: Scissors,
  wallet: Wallet,
};
---

<BaseLayout title={page.title} description={page.description}>
  <section class="page-hero">
    <div class="page-hero__media">
      <img src={page.heroImage} alt={page.heroTitle} />
    </div>

    <div class="container page-hero__inner">
      <div class="page-hero__content">

        <h1>{page.heroTitle}</h1>

        <p>{page.heroText}</p>

        <div class="page-hero__actions">
          <a class="btn btn--primary" href={site.phoneHref}>
            <Phone size={18} stroke-width={2.2} class="cta-icon" />
            Chiama ora
          </a>

          <a class="btn btn--ghost" href="/contatti.html">
            Vieni in negozio
          </a>
        </div>
      </div>

      <div class="page-hero__showcase" aria-hidden="true">
        <img src={heroVisual} alt="" />
      </div>
    </div>
  </section>

  <section class="section section--white">
    <div class="container intro">
      <span class="eyebrow">{page.introLabel ?? 'Cosa trovi'}</span>
      <h2>{page.introTitle}</h2>
      <p>{page.introText}</p>
    </div>
  </section>

  <section class="section products-section">
    <div class="container products-grid">
      {groups.map((group, index) => {
        const Icon = icons[group.icon] ?? BadgeCheck;
        const groupCategory = categoryBySlug.get(group.slug);
        const groupImage = group.image ?? groupCategory?.image;

        return (
          <article class="product-card" id={group.slug}>
            {groupImage ? (
              <div class="product-card__media">
                <img src={groupImage} alt={group.title} loading="lazy" />

                <div class="product-card__top">
                  <span>{String(index + 1).padStart(2, '0')}</span>
                  <div class="product-card__icon-wrap">
                    <Icon />
                  </div>
                </div>
              </div>
            ) : (
              <div class="product-card__top product-card__top--plain">
                <span>{String(index + 1).padStart(2, '0')}</span>
                <div class="product-card__icon-wrap">
                  <Icon />
                </div>
              </div>
            )}

            <h3>{group.title}</h3>
            <p>{group.text}</p>

            {group.items?.length ? (
              <ul>
                {group.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            ) : null}
          </article>
        );
      })}
    </div>
  </section>

  {relatedCategories.length > 0 ? (
    <section class="section category-rail-section">
      <div class="container category-rail">
        <div class="category-rail__head">
          <span class="eyebrow">Catalogo Buffetti</span>
          <h2>Sottocategorie collegate</h2>
          <p>
            Una mappa rapida delle famiglie prodotto del gruppo, riadattata alle richieste piu comuni del negozio.
          </p>
        </div>

        <div class="category-rail__grid">
          {relatedCategories.map((category) => (
            <a class="category-tile" href={category.href}>
              <img src={category.image} alt={category.label} loading="lazy" />
              <strong>{category.label}</strong>
              <span>{category.summary}</span>
              <ul>
                {category.items.slice(0, 5).map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </a>
          ))}
        </div>
      </div>
    </section>
  ) : null}

  <ProductShowcase showcase={page.showcase} />

  <BrandShowcase brands={page.brands} />

  <section class="section section--white">
    <div class="container split">
      <div class="split__content">
        <span class="eyebrow">Perché scegliere Buffetti Cucchi</span>

        <h2>{page.focusTitle}</h2>

        <p>{page.focusText}</p>

        <ul>
          {page.focusList.map((item) => (
            <li>
              <Check />
              {item}
            </li>
          ))}
        </ul>
      </div>

      <div class="split__image">
        <img src={page.focusImage} alt={page.focusTitle} loading="lazy" />
      </div>
    </div>
  </section>

  <section class="feature-strip">
    <div class="container feature-strip__inner">
      <div>
        <span class="eyebrow">{page.featureLabel ?? 'In negozio'}</span>
        <h2>{page.featureTitle ?? 'Un punto vendita pratico, vicino e completo'}</h2>
      </div>

      <p>
        {page.featureText ??
          'Passa in negozio per vedere i prodotti dal vivo, chiedere informazioni e scegliere la soluzione più adatta alle tue esigenze.'}
      </p>
    </div>
  </section>

  <section class="contact-band">
    <div class="container contact-band__inner">
      <div>
        <span class="eyebrow">Contatto rapido</span>
        <h2>{page.ctaText}</h2>
        <p>
          Passa in negozio in Viale Matteotti, 593 a Cesena oppure contattaci per informazioni
          su disponibilità, servizi e forniture.
        </p>
      </div>

      <div class="contact-band__actions">
        <a class="btn btn--primary" href={site.phoneHref}>{page.ctaButton}</a>
        <a class="btn btn--ghost" href={site.emailHref}>Invia una email</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    position: relative;
    min-height: 540px;
    display: grid;
    align-items: center;
    overflow: hidden;
    background: var(--color-primary-dark);
  }

  .page-hero__media {
    position: absolute;
    inset: 0;
  }

  .page-hero__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 26% 24%, rgba(0, 166, 232, 0.24), transparent 28%),
      linear-gradient(90deg, rgba(0, 25, 58, 0.94), rgba(0, 38, 80, 0.72) 48%, rgba(0, 31, 69, 0.18)),
      linear-gradient(0deg, rgba(0, 24, 54, 0.58), transparent 58%);
  }

  .page-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .page-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(280px, 0.48fr);
    gap: 42px;
    align-items: center;
  }

  .page-hero__content {
    max-width: 720px;
    color: #fff;
  }

  .page-hero__showcase {
    min-height: 330px;
    display: grid;
    place-items: center;
    padding: 20px;
    border: 0;
    border-radius: 0;
    background:
      radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.86), rgba(255, 255, 255, 0.34) 42%, transparent 68%);
    box-shadow: none;
  }

  .page-hero__showcase img {
    width: min(100%, 340px);
    max-height: 270px;
    object-fit: contain;
    filter: drop-shadow(0 28px 38px rgba(0, 31, 69, 0.24));
  }

  .eyebrow {
    display: inline-flex;
    margin-bottom: 16px;
    color: var(--color-accent);
    font-weight: var(--weight-bold);
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .page-hero .eyebrow {
    color: #e5f7ff;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(0, 166, 232, 0.24);
    border: 1px solid rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(10px);
  }

  .page-hero h1 {
    max-width: 720px;
    margin: 0;
    color: #fff;
    font-size: clamp(2.55rem, 5vw, 5rem);
    line-height: 0.92;
    letter-spacing: -0.06em;
  }

  .page-hero p {
    max-width: 610px;
    margin: 24px 0 0;
    color: rgba(255, 255, 255, 0.86);
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .page-hero__actions {
    margin-top: 32px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .page-hero__actions svg {
    width: 16px;
    height: 16px;
  }

  .intro {
    max-width: 850px;
    text-align: center;
  }

  .intro h2,
  .split h2,
  .feature-strip h2,
  .contact-band h2 {
    margin: 0;
    color: var(--color-primary-dark);
    font-size: clamp(2rem, 4vw, 3.55rem);
    line-height: 0.98;
    letter-spacing: -0.052em;
  }

  .intro p {
    max-width: 720px;
    margin: 22px auto 0;
    color: var(--color-muted);
    font-size: 1.06rem;
    line-height: 1.8;
  }

  .cta-icon {
    margin-right: 5px;
  }

  .products-section {
    background:
      radial-gradient(circle at 8% 0%, rgba(0, 166, 232, 0.14), transparent 30%),
      linear-gradient(180deg, #f6fbff, #ffffff);
  }

  .category-rail-section {
    background: #fff;
  }

  .category-rail {
    display: grid;
    grid-template-columns: minmax(260px, 0.45fr) minmax(0, 1fr);
    gap: 38px;
    align-items: start;
  }

  .category-rail__head {
    position: sticky;
    top: 226px;
  }

  .category-rail h2 {
    margin: 0;
    color: var(--color-primary-dark);
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 0.98;
    letter-spacing: -0.048em;
  }

  .category-rail__head p {
    margin: 18px 0 0;
    color: var(--color-muted);
    line-height: 1.75;
  }

  .category-rail__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .category-tile {
    min-height: 250px;
    padding: 22px;
    border: 1px solid #dce6f1;
    border-radius: 4px;
    background: #fff;
    box-shadow: 0 16px 42px rgba(0, 31, 69, 0.07);
    transition: transform 0.18s ease, border-color 0.18s ease;
  }

  .category-tile > img {
    width: 100%;
    height: 132px;
    object-fit: contain;
    margin-bottom: 18px;
    padding: 0;
    background: transparent;
  }

  .category-tile:hover {
    transform: translateY(-4px);
    border-color: rgba(0, 0, 232, 0.28);
  }

  .category-tile strong {
    display: block;
    color: #0000e8;
    font-size: 1.18rem;
    line-height: 1.15;
  }

  .category-tile > span {
    display: block;
    margin-top: 10px;
    color: var(--color-muted);
    line-height: 1.55;
  }

  .category-tile ul {
    margin: 18px 0 0;
    padding: 0;
    display: grid;
    gap: 8px;
    list-style: none;
  }

  .category-tile li {
    position: relative;
    padding-left: 16px;
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 720;
    line-height: 1.35;
  }

  .category-tile li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.58em;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: #00a6e8;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }

  .product-card {
    position: relative;
    overflow: hidden;
    min-height: 370px;
    padding: 22px;
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0.9)),
      radial-gradient(circle at 88% 12%, rgba(0, 166, 232, 0.12), transparent 36%);
    border: 1px solid rgba(204, 221, 237, 0.84);
    box-shadow: 0 18px 48px rgba(15, 38, 67, 0.075);
    transition:
      transform 0.24s ease,
      box-shadow 0.24s ease,
      border-color 0.24s ease;
  }

  .product-card::after {
    content: "";
    position: absolute;
    right: -58px;
    bottom: -58px;
    width: 120px;
    height: 120px;
    border-radius: 999px;
    background: rgba(0, 166, 232, 0.11);
  }

  .product-card:hover {
    transform: translateY(-6px);
    border-color: rgba(0, 166, 232, 0.35);
    box-shadow: 0 32px 90px rgba(15, 38, 67, 0.13);
  }

  .product-card__media {
    position: relative;
    z-index: 1;
    height: 164px;
    display: grid;
    place-items: center;
    margin: 0 0 24px;
    padding: 18px 18px 34px;
    border-radius: 0;
    background:
      radial-gradient(circle at 50% 52%, rgba(0, 166, 232, 0.12), transparent 54%);
  }

  .product-card__media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 18px 22px rgba(0, 31, 69, 0.1));
  }

  .product-card__top {
    position: absolute;
    z-index: 2;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin: 0;
  }

  .product-card__top--plain {
    position: relative;
    margin-bottom: 26px;
  }

  .product-card__top > span {
    color: var(--color-accent);
    font-weight: var(--weight-bold);
  }

  .product-card__icon-wrap {
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    color: var(--color-primary);
    background:
      radial-gradient(circle at 30% 20%, rgba(255, 255, 255, 0.82), transparent 32%),
      linear-gradient(135deg, rgba(0, 166, 232, 0.2), rgba(0, 75, 141, 0.08));
  }

  .product-card__icon-wrap svg {
    width: 25px;
    height: 25px;
  }

  .product-card h3 {
    position: relative;
    z-index: 1;
    margin: 0;
    color: var(--color-primary);
    font-size: 1.45rem;
    line-height: 1.08;
    letter-spacing: -0.032em;
  }

  .product-card p {
    position: relative;
    z-index: 1;
    margin: 14px 0 0;
    color: var(--color-muted);
    line-height: 1.7;
  }

  .product-card ul {
    position: relative;
    z-index: 1;
    margin: 22px 0 0;
    padding: 0;
    display: grid;
    gap: 10px;
    list-style: none;
  }

  .product-card li {
    position: relative;
    padding-left: 24px;
    color: var(--color-text);
    font-size: 0.95rem;
    font-weight: 720;
    line-height: 1.45;
  }

  .product-card li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.52em;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--color-accent);
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 56px;
    align-items: center;
  }

  .split__content p {
    margin: 20px 0 0;
    color: var(--color-muted);
    line-height: 1.8;
    font-size: 1.04rem;
  }

  .split__content ul {
    margin: 28px 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 14px;
  }

  .split__content li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: var(--color-text);
    font-weight: 760;
    line-height: 1.45;
  }

  .split__content li svg {
    width: 18px;
    height: 18px;
    flex: 0 0 auto;
    margin-top: 2px;
    color: var(--color-accent);
  }

  .split__image {
    min-height: 440px;
    overflow: hidden;
    border-radius: 34px;
    background: #dce8f5;
    box-shadow: var(--shadow-soft);
  }

  .split__image img {
    width: 100%;
    height: 100%;
    min-height: 440px;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .split__image:hover img {
    transform: scale(1.035);
  }

  .feature-strip {
    padding: 78px 0;
    background:
      radial-gradient(circle at 82% 20%, rgba(0, 166, 232, 0.24), transparent 30%),
      linear-gradient(135deg, #eef8ff, #ffffff);
  }

  .feature-strip__inner {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    align-items: center;
    gap: 52px;
  }

  .feature-strip p {
    margin: 0;
    color: var(--color-muted);
    font-size: 1.08rem;
    line-height: 1.85;
  }

  .contact-band {
    padding: 78px 0;
    color: #fff;
    background:
      radial-gradient(circle at 88% 18%, rgba(0, 166, 232, 0.34), transparent 30%),
      linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  }

  .contact-band__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 34px;
  }

  .contact-band .eyebrow,
  .contact-band h2,
  .contact-band p {
    color: #fff;
  }

  .contact-band p {
    max-width: 680px;
    margin: 18px 0 0;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.75;
  }

  .contact-band__actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  @media (max-width: 1100px) {
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 920px) {
    .page-hero {
      min-height: auto;
      padding: 138px 0 58px;
    }

    .page-hero__inner {
      grid-template-columns: 1fr;
    }

    .page-hero__showcase {
      min-height: 240px;
      padding: 24px;
    }

    .split,
    .category-rail,
    .feature-strip__inner {
      grid-template-columns: 1fr;
    }

    .category-rail__head {
      position: static;
    }

    .contact-band__inner {
      align-items: flex-start;
      flex-direction: column;
    }

    .contact-band__actions {
      justify-content: flex-start;
    }
  }

  @media (max-width: 680px) {
    .page-hero {
      padding-top: 118px;
    }

    .page-hero h1 {
      font-size: clamp(2.35rem, 13vw, 3.7rem);
    }

    .page-hero p {
      font-size: 1rem;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }

    .category-rail__grid {
      grid-template-columns: 1fr;
    }

    .product-card {
      min-height: auto;
      padding: 26px;
      border-radius: 26px;
    }

    .split__image,
    .split__image img {
      min-height: 300px;
    }
  }
</style>
