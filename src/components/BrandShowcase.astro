---
const { brands } = Astro.props;
const items = brands?.items ?? [];
const hasImages = items.some((brand: { image?: string }) => brand.image);
---

{items.length > 0 && (
  <section class={`brand-showcase ${hasImages ? 'brand-showcase--visual' : ''}`}>
    <div class="container brand-showcase__inner">
      <div class="brand-showcase__head">
        <span class="eyebrow">{brands.label}</span>
        <h2>{brands.title}</h2>
        <p>{brands.text}</p>
      </div>

      <div class="brand-showcase__list" aria-label={brands.title}>
        {items.map((brand: { image?: string; logo?: string | null; name: string; alt?: string; }) => (
          <figure class="brand-showcase__item">
            {brand.image ? (
              <>
                <div class="brand-showcase__image">
                  <img src={brand.image} alt={brand.alt ?? brand.name} loading="lazy" />
                </div>
                <figcaption>{brand.name}</figcaption>
              </>
            ) : brand.logo ? (
              <img src={brand.logo} alt={brand.name} loading="lazy" />
            ) : (
              <span>{brand.name}</span>
            )}
          </figure>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .brand-showcase {
    padding: 84px 0;
    background:
      radial-gradient(circle at 12% 20%, rgba(0, 166, 232, 0.11), transparent 28%),
      linear-gradient(180deg, #ffffff, #f7fbff);
  }

  .brand-showcase__inner {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
    gap: 56px;
    align-items: center;
  }

  .brand-showcase__head {
    max-width: 560px;
  }

  .brand-showcase h2 {
    margin: 0;
    color: var(--color-primary-dark);
    font-size: clamp(2rem, 4vw, 3.45rem);
    line-height: 0.98;
    letter-spacing: -0.052em;
  }

  .brand-showcase p {
    margin: 20px 0 0;
    color: var(--color-muted);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .brand-showcase__list {
    display: flex;
    flex-wrap: wrap;
    gap: 18px 28px;
    align-items: center;
  }

  .brand-showcase__item {
    position: relative;
    margin: 0;
    display: inline-flex;
    align-items: center;
    min-height: 54px;
    color: var(--color-primary);
    font-size: clamp(1.15rem, 2vw, 1.8rem);
    font-weight: 850;
    letter-spacing: -0.045em;
  }

  .brand-showcase__item::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 6px;
    height: 8px;
    border-radius: 999px;
    background: rgba(0, 166, 232, 0.16);
    z-index: 0;
  }

  .brand-showcase__item span,
  .brand-showcase__item img {
    position: relative;
    z-index: 1;
  }

  .brand-showcase__item img {
    max-width: 150px;
    max-height: 52px;
    object-fit: contain;
  }

  .brand-showcase--visual .brand-showcase__inner {
    grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
    align-items: start;
  }

  .brand-showcase--visual .brand-showcase__list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
    align-items: stretch;
  }

  .brand-showcase--visual .brand-showcase__item {
    display: flex;
    min-height: 0;
    flex-direction: column;
    gap: 12px;
    align-items: stretch;
    color: var(--color-primary-dark);
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0;
    text-align: center;
  }

  .brand-showcase--visual .brand-showcase__item::after {
    display: none;
  }

  .brand-showcase__image {
    display: grid;
    place-items: center;
    aspect-ratio: 4 / 3;
    padding: 10px;
    border: 0;
    border-radius: 0;
    background: radial-gradient(circle at 50% 50%, rgba(0, 166, 232, 0.1), transparent 56%);
    box-shadow: none;
  }

  .brand-showcase__image img {
    width: 100%;
    height: 100%;
    max-width: none;
    max-height: none;
    object-fit: contain;
    filter: drop-shadow(0 16px 18px rgba(0, 31, 69, 0.1));
  }

  .brand-showcase__item figcaption {
    line-height: 1.25;
  }

  @media (max-width: 920px) {
    .brand-showcase__inner {
      grid-template-columns: 1fr;
      gap: 34px;
    }
  }

  @media (max-width: 680px) {
    .brand-showcase {
      padding: 64px 0;
    }

    .brand-showcase__list {
      gap: 14px 22px;
    }

    .brand-showcase--visual .brand-showcase__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
    }
  }

  @media (max-width: 460px) {
    .brand-showcase--visual .brand-showcase__list {
      grid-template-columns: 1fr;
    }
  }
</style>
