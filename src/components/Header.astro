---
import { navItems } from '../data/nav';
import { digitalServices, productCategories, shopFocusAreas } from '../data/catalog';
import { site } from '../data/site';
import { ChevronDown, Mail, MapPin, Menu, Phone, Search } from '@lucide/astro';

const currentPath = Astro.url.pathname;

const normalizePath = (path: string) =>
  path.replace('/index.html', '/').replace('.html', '').split('#')[0];

const isActive = (href: string) => {
  const cleanHref = normalizePath(href);
  const cleanPath = normalizePath(currentPath);

  if (href === '/index.html') return cleanPath === '/';
  if (href.startsWith('/prodotti/') && cleanPath.startsWith('/prodotti/')) return true;
  return cleanPath === cleanHref;
};

const previewCategories = productCategories.slice(0, 6);
const searchIndex = [
  { label: 'Home', href: '/index.html', type: 'Pagina', keywords: 'negozio buffetti cucchi cesena cartoleria' },
  { label: 'Contatti', href: '/contatti.html', type: 'Pagina', keywords: 'telefono email indirizzo orari viale matteotti' },
  { label: 'Servizi in negozio', href: '/servizi.html', type: 'Pagina', keywords: 'pec spid firma digitale stampa fotocopie timbri spedizioni' },
  { label: 'Cancelleria', href: '/cancelleria.html', type: 'Reparto', keywords: 'penne matite carta quaderni archivio' },
  { label: 'Articoli per la scuola', href: '/articoli-per-la-scuola.html', type: 'Reparto', keywords: 'zaini astucci diari colori quaderni album' },
  { label: "Articoli per l'ufficio", href: '/articoli-per-l-ufficio.html', type: 'Reparto', keywords: 'ufficio toner archiviazione macchine carta' },
  { label: 'Arredo ufficio', href: '/arredamento.html', type: 'Reparto', keywords: 'sedie scrivanie lampade ergonomia' },
  { label: 'Idee regalo e pelletteria', href: '/pelletteria-e-regalistica.html', type: 'Reparto', keywords: 'regali borse penne pelletteria' },
  ...productCategories.map((category) => ({
    label: category.label,
    href: category.href,
    type: 'Catalogo',
    keywords: `${category.summary} ${category.items.join(' ')}`,
  })),
  ...digitalServices.map((service) => ({
    label: service.label,
    href: service.href,
    type: 'Servizio',
    keywords: `${service.badge} ${service.text} ${service.detail} ${service.items.join(' ')}`,
  })),
  ...shopFocusAreas.map((area) => ({
    label: area.label,
    href: area.href,
    type: 'Area',
    keywords: `${area.text} ${(area.items ?? []).join(' ')}`,
  })),
];
---

<header class="site-header">
  <div class="header-ribbon">
    <div class="container header-ribbon__inner">
      <a href="/contatti.html">Chi siamo</a>
      <a href="/servizi.html">Assistenza</a>
      <a href={site.facebook} target="_blank" rel="noopener noreferrer">Facebook</a>
      <a href={site.instagram} target="_blank" rel="noopener noreferrer">Instagram</a>
      <a href={site.mapsUrl} target="_blank" rel="noopener noreferrer">
        <MapPin size={15} stroke-width={2.2} />
        Cesena, Viale Matteotti 593
      </a>
    </div>
  </div>

  <div class="container header-main">
    <a class="brand" href="/index.html" aria-label="Torna alla home">
      <img src="/images/logo-buffetti.png" alt="Logo Buffetti Cucchi" width="120" height="76" />
      <span>
        <strong>Buffetti Cucchi</strong>
        <small>s.a.s. di Cucchi Elisabetta & C.</small>
      </span>
    </a>

    <form class="site-search" action="/index.html" role="search" autocomplete="off">
      <label class="sr-only" for="site-search-input">Cerca prodotti e servizi</label>
      <input id="site-search-input" name="q" type="search" placeholder="Cerca prodotti, servizi, SPID..." />
      <button type="submit" aria-label="Cerca">
        <Search size={24} stroke-width={2.2} />
      </button>
      <div class="search-suggestions" id="site-search-suggestions" hidden></div>
    </form>

    <div class="header-actions" aria-label="Contatti rapidi">
      <a class="contact-button" href={site.phoneHref}>
        <Phone size={18} stroke-width={2.2} />
        Chiama
      </a>
      <a class="icon-action" href={site.emailHref} aria-label="Invia email">
        <Mail size={20} stroke-width={2.2} />
      </a>
      <a class="icon-action" href={site.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram Buffetti Cucchi">
        <img src="/images/instagram.svg" alt="" width="20" height="20" />
      </a>
      <a class="icon-action icon-action--facebook" href={site.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook Buffetti Cucchi">
        <img src="/images/facebook.svg" alt="" width="18" height="18" />
      </a>
    </div>

    <input class="nav-toggle" type="checkbox" id="menu-toggle" />
    <label class="menu-button" for="menu-toggle" aria-label="Apri menu">
      <Menu size={24} stroke-width={2.3} />
    </label>
  </div>

  <nav class="site-nav" aria-label="Navigazione principale">
    <div class="container nav-inner">
      {navItems.map((item) => (
        <div class:list={['nav-item', item.featured?.length && 'nav-item--has-menu']}>
          <a
            class:list={[
              'nav-link',
              isActive(item.href) && 'nav-link--active',
            ]}
            href={item.href}
          >
            {item.label}
            {item.featured?.length ? <ChevronDown size={15} stroke-width={2.4} /> : null}
          </a>

          {item.featured?.length ? (
            <div class="mega-menu">
              <div class="mega-menu__panel">
                <div class="mega-menu__intro">
                  <span>{item.label}</span>
                  <strong>{item.label === 'Catalogo prodotti' ? 'Scegli la famiglia prodotto' : 'Servizi e reparti Cucchi'}</strong>
                  <p>
                    {item.label === 'Catalogo prodotti'
                      ? 'Ogni voce apre una pagina dedicata con sottocategorie, immagini e prodotti da chiedere in negozio.'
                      : 'Percorsi rapidi per scuola, ufficio, pratiche, stampa e supporto al banco.'}
                  </p>
                </div>

                <div class="mega-menu__grid">
                  {item.featured.slice(0, 12).map((entry) => (
                    <a href={entry.href}>
                      {entry.image ? <img src={entry.image} alt="" loading="lazy" /> : null}
                      <strong>{entry.label}</strong>
                      <span>{entry.summary ?? entry.text}</span>
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : null}
        </div>
      ))}
    </div>
  </nav>

  <div class="mobile-categories" aria-label="Categorie principali">
    <div class="container mobile-categories__inner">
      {previewCategories.map((category) => (
        <a href={category.href}>{category.label}</a>
      ))}
    </div>
  </div>
</header>

<script type="application/json" id="site-search-data" set:html={JSON.stringify(searchIndex)} />
<script>
  const searchForm = document.querySelector('.site-search');
  const searchInput = document.querySelector('#site-search-input');
  const suggestionBox = document.querySelector('#site-search-suggestions');
  const dataNode = document.querySelector('#site-search-data');
  const searchItems = dataNode ? JSON.parse(dataNode.textContent || '[]') : [];

  const normalize = (value) =>
    value
      .toString()
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '');

  const findMatches = (query) => {
    const terms = normalize(query).split(/\s+/).filter(Boolean);
    if (!terms.length) return [];

    return searchItems
      .map((item) => {
        const haystack = normalize(`${item.label} ${item.type} ${item.keywords}`);
        const score = terms.reduce((total, term) => {
          if (normalize(item.label).startsWith(term)) return total + 8;
          if (haystack.includes(term)) return total + 3;
          return total;
        }, 0);
        return { ...item, score };
      })
      .filter((item) => item.score > 0)
      .sort((a, b) => b.score - a.score || a.label.localeCompare(b.label))
      .slice(0, 7);
  };

  const submitBestMatch = (event, input) => {
    const firstMatch = findMatches(input?.value || '')[0];
    if (!firstMatch) return;
    event.preventDefault();
    window.location.href = firstMatch.href;
  };

  const renderSuggestions = () => {
    if (!searchInput || !suggestionBox) return;
    const matches = findMatches(searchInput.value);

    if (!matches.length) {
      suggestionBox.hidden = true;
      suggestionBox.innerHTML = '';
      return;
    }

    suggestionBox.innerHTML = matches
      .map(
        (item) => `
          <a class="search-result" href="${item.href}">
            <span class="search-result__type">${item.type}</span>
            <strong class="search-result__label">${item.label}</strong>
            <small class="search-result__hint">Apri ${item.type.toLowerCase()} dedicata</small>
          </a>
        `
      )
      .join('');
    suggestionBox.hidden = false;
  };

  searchInput?.addEventListener('input', renderSuggestions);
  searchInput?.addEventListener('focus', renderSuggestions);
  searchInput?.addEventListener('keydown', (event) => {
    if (event.key === 'Enter') submitBestMatch(event, searchInput);
  });
  document.addEventListener('click', (event) => {
    if (!searchForm?.contains(event.target)) suggestionBox.hidden = true;
  });
  searchForm?.addEventListener('submit', (event) => submitBestMatch(event, searchInput));

  document.querySelectorAll('.hero-search').forEach((form) => {
    const input = form.querySelector('input[type="search"]');
    input?.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') submitBestMatch(event, input);
    });
    form.addEventListener('submit', (event) => submitBestMatch(event, input));
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 80;
    background: rgba(255, 255, 255, 0.98);
    border-bottom: 1px solid #dde5ef;
    box-shadow: 0 12px 32px rgba(0, 31, 69, 0.06);
  }

  .header-ribbon {
    color: #fff;
    background: #0000e8;
  }

  .header-ribbon__inner {
    min-height: 34px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 26px;
    font-size: 0.86rem;
    font-weight: 760;
  }

  .header-ribbon a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .header-main {
    min-height: 118px;
    display: grid;
    grid-template-columns: minmax(265px, 0.75fr) minmax(280px, 600px) auto;
    align-items: center;
    gap: 28px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    min-width: 0;
  }

  .brand img {
    width: 92px;
    height: auto;
    flex: 0 0 auto;
  }

  .brand span {
    display: grid;
    gap: 2px;
    color: var(--color-primary-dark);
    line-height: 1.12;
  }

  .brand strong {
    font-size: 1.24rem;
    letter-spacing: -0.02em;
  }

  .brand small {
    font-size: 0.86rem;
    font-weight: 760;
  }

  .site-search {
    position: relative;
    height: 50px;
    display: grid;
    grid-template-columns: 1fr 54px;
    align-items: center;
    border: 1.5px solid #060a1d;
    border-radius: 999px;
    background: #fff;
    box-shadow: 0 12px 32px rgba(0, 31, 69, 0.04);
  }

  .site-search input {
    min-width: 0;
    height: 100%;
    padding: 0 22px;
    border: 0;
    outline: 0;
    color: var(--color-primary-dark);
    background: transparent;
  }

  .site-search button {
    height: 100%;
    border: 0;
    color: #0000e8;
    background: transparent;
    cursor: pointer;
  }

  .search-suggestions {
    position: absolute;
    z-index: 100;
    top: calc(100% + 12px);
    left: 50%;
    width: min(760px, calc(100vw - 32px));
    max-height: min(520px, calc(100vh - 190px));
    overflow: hidden;
    border: 1px solid rgba(0, 0, 232, 0.18);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.98);
    box-shadow: 0 30px 90px rgba(0, 31, 69, 0.24);
    transform: translateX(-50%);
    backdrop-filter: blur(18px);
  }

  :global(.search-result) {
    position: relative;
    min-height: 78px;
    padding: 15px 54px 15px 18px;
    display: grid;
    grid-template-columns: 94px minmax(0, 1fr);
    gap: 2px 16px;
    align-items: center;
    border-bottom: 1px solid #dfe8f2;
    transition: background 0.16s ease, transform 0.16s ease;
  }

  :global(.search-result:last-child) {
    border-bottom: 0;
  }

  :global(.search-result:hover),
  :global(.search-result:focus) {
    background:
      linear-gradient(90deg, rgba(0, 0, 232, 0.08), rgba(0, 166, 232, 0.05));
  }

  :global(.search-result::after) {
    content: "→";
    position: absolute;
    right: 20px;
    top: 50%;
    color: #0000e8;
    font-size: 1.35rem;
    font-weight: 850;
    transform: translateY(-50%);
  }

  :global(.search-result__type) {
    justify-self: start;
    padding: 7px 9px;
    border-radius: 999px;
    color: #0000e8;
    background: #eef3ff;
    font-size: 0.72rem;
    font-weight: 850;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  :global(.search-result__label) {
    color: var(--color-primary-dark);
    font-size: 1.08rem;
    line-height: 1.2;
  }

  :global(.search-result__hint) {
    grid-column: 2;
    color: var(--color-muted);
    font-size: 0.86rem;
    font-weight: 650;
  }

  .header-actions {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 12px;
  }

  .contact-button,
  .icon-action {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #0000e8;
    font-weight: 830;
    transition: transform 0.18s ease, background 0.18s ease;
  }

  .contact-button {
    gap: 9px;
    padding: 0 18px;
    color: #fff;
    background: #0000e8;
    border-radius: 4px;
  }

  .icon-action {
    width: 48px;
    border-radius: 999px;
    background: #f3f6fb;
  }

  .icon-action img {
    width: 18px;
    height: 18px;
  }

  .icon-action--facebook {
    background: #eef3ff;
  }

  .contact-button:hover,
  .icon-action:hover {
    transform: translateY(-2px);
  }

  .site-nav {
    border-top: 1px solid #dde5ef;
  }

  .nav-inner {
    min-height: 52px;
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    position: relative;
    min-height: 52px;
    padding: 0 18px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #050915;
    font-size: 0.95rem;
    font-weight: 820;
    white-space: nowrap;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    left: 18px;
    right: 18px;
    bottom: 0;
    height: 3px;
    background: #00a6e8;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.18s ease;
  }

  .nav-link:hover,
  .nav-link--active {
    color: #0000e8;
  }

  .nav-link:hover::after,
  .nav-link--active::after {
    transform: scaleX(1);
  }

  .mega-menu {
    position: absolute;
    left: 0;
    top: 100%;
    width: min(1040px, calc(100vw - 32px));
    padding-top: 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s ease;
  }

  .nav-item:hover .mega-menu,
  .nav-item:focus-within .mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .mega-menu__panel {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 28px;
    padding: 28px;
    border: 1px solid #d9e3ef;
    background: #fff;
    box-shadow: 0 34px 90px rgba(0, 31, 69, 0.18);
  }

  .mega-menu__intro {
    padding: 22px;
    color: #fff;
    background: #0000e8;
    border-radius: 4px;
  }

  .mega-menu__intro span {
    display: block;
    margin-bottom: 26px;
    color: rgba(255, 255, 255, 0.74);
    font-size: 0.78rem;
    font-weight: 830;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .mega-menu__intro strong {
    display: block;
    font-size: 1.55rem;
    line-height: 1.08;
    letter-spacing: -0.03em;
  }

  .mega-menu__intro p {
    margin: 14px 0 0;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.55;
  }

  .mega-menu__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 4px 20px;
  }

  .mega-menu__grid a {
    min-height: 92px;
    padding: 11px 0;
    border-bottom: 1px solid #e8eef5;
  }

  .mega-menu__grid img {
    width: 44px;
    height: 34px;
    object-fit: contain;
    float: right;
    margin-left: 10px;
    margin-bottom: 4px;
  }

  .mega-menu__grid strong,
  .mega-menu__grid span {
    display: block;
  }

  .mega-menu__grid strong {
    color: #050915;
    font-size: 0.98rem;
    line-height: 1.2;
  }

  .mega-menu__grid span {
    margin-top: 5px;
    color: #62718a;
    font-size: 0.84rem;
    line-height: 1.38;
  }

  .mobile-categories {
    display: none;
  }

  .nav-toggle,
  .menu-button {
    display: none;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  @media (max-width: 1120px) {
    .header-main {
      grid-template-columns: 1fr auto;
      min-height: 88px;
      padding: 14px 0 12px;
      gap: 12px 16px;
    }

    .header-actions,
    .site-nav {
      display: none;
    }

    .brand {
      grid-column: 1;
      grid-row: 1;
    }

    .site-search {
      grid-column: 1 / -1;
      grid-row: 2;
      height: 48px;
      width: 100%;
    }

    .search-suggestions {
      width: min(680px, calc(100vw - 24px));
      max-height: min(460px, calc(100vh - 170px));
    }

    .menu-button {
      grid-column: 2;
      grid-row: 1;
      width: 46px;
      height: 46px;
      display: grid;
      place-items: center;
      color: #0000e8;
      background: #f1f5fb;
      border-radius: 999px;
      cursor: pointer;
    }

    .site-header:has(.nav-toggle:checked) .site-nav {
      display: block;
    }

    .site-header:has(.nav-toggle:checked) .nav-inner {
      padding: 12px 0 16px;
      display: grid;
      gap: 4px;
    }

    .nav-link {
      width: 100%;
      min-height: 46px;
      justify-content: space-between;
      padding: 0 14px;
      border-radius: 4px;
      background: #f3f6fb;
    }

    .nav-link::after,
    .mega-menu {
      display: none;
    }

    .mobile-categories {
      display: block;
      border-top: 1px solid #dde5ef;
    }

    .mobile-categories__inner {
      min-height: 44px;
      display: flex;
      gap: 10px;
      overflow-x: auto;
      align-items: center;
      scrollbar-width: none;
    }

    .mobile-categories__inner::-webkit-scrollbar {
      display: none;
    }

    .mobile-categories a {
      flex: 0 0 auto;
      padding: 7px 10px;
      color: #0000e8;
      background: #f3f6fb;
      border-radius: 4px;
      font-size: 0.82rem;
      font-weight: 820;
    }
  }

  @media (max-width: 680px) {
    .site-header {
      position: sticky;
    }

    .header-ribbon__inner {
      justify-content: flex-start;
      overflow-x: auto;
      gap: 18px;
      white-space: nowrap;
    }

    .brand img {
      width: 76px;
    }

    .brand strong {
      font-size: 1rem;
    }

    .brand small {
      max-width: 190px;
      font-size: 0.76rem;
    }

    .site-search {
      height: 46px;
      grid-template-columns: 1fr 48px;
    }

    .site-search input {
      padding: 0 16px;
      font-size: 0.95rem;
    }

    .search-suggestions {
      top: calc(100% + 8px);
      width: calc(100vw - 20px);
      max-height: min(420px, calc(100vh - 154px));
      border-radius: 10px;
    }

    :global(.search-result) {
      min-height: 74px;
      padding: 14px 42px 14px 14px;
      grid-template-columns: 78px minmax(0, 1fr);
      gap: 2px 10px;
    }

    :global(.search-result__type) {
      padding: 6px 8px;
      font-size: 0.66rem;
    }

    :global(.search-result__label) {
      font-size: 0.98rem;
    }

    :global(.search-result__hint) {
      font-size: 0.8rem;
    }
  }
</style>
