---
import { site } from '../data/site';
import { digitalServices, productCategories } from '../data/catalog';
import { ExternalLink, Mail, MapPin, Phone } from '@lucide/astro';

const footerProducts = productCategories.slice(0, 7);
const footerServices = digitalServices.slice(0, 5);
---

<footer class="footer">
  <div class="footer-topline"></div>

  <div class="container footer-inner">
    <div class="footer-brand">
      <div class="footer-logo-row">
        <img src="/images/logo-buffetti.png" alt="Logo Buffetti Cucchi" width="104" height="66" />
        <div>
          <strong>Buffetti Cucchi</strong>
          <span>Cartoleria, ufficio e servizi a Cesena</span>
        </div>
      </div>

      <p>
        Un negozio Buffetti locale: prodotti per scuola e ufficio, servizi digitali,
        stampa, timbri, spedizioni, pelletteria e supporto diretto al banco.
      </p>

      <div class="footer-social">
        <a href={site.facebook} target="_blank" rel="noopener noreferrer">
          <img src="/images/facebook.svg" alt="" />
          Facebook
        </a>
        <a href={site.instagram} target="_blank" rel="noopener noreferrer">
          <img src="/images/instagram.svg" alt="" />
          Instagram
        </a>
      </div>
    </div>

    <div class="footer-col">
      <h2>Catalogo</h2>
      <nav aria-label="Categorie prodotto footer">
        {footerProducts.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </nav>
    </div>

    <div class="footer-col">
      <h2>Servizi</h2>
      <nav aria-label="Servizi footer">
        {footerServices.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
        <a href="/servizi.html">Tutti i servizi</a>
      </nav>
    </div>

    <div class="footer-contact-card">
      <span>Contatto rapido</span>
      <h2>Chiedi prima di passare</h2>
      <a href={site.phoneHref}>
        <Phone size={18} stroke-width={2.2} />
        {site.phone}
      </a>
      <a href={site.emailHref}>
        <Mail size={18} stroke-width={2.2} />
        {site.email}
      </a>
      <a href={site.mapsUrl} target="_blank" rel="noopener noreferrer">
        <MapPin size={18} stroke-width={2.2} />
        Viale Matteotti, 593
      </a>
    </div>
  </div>

  <div class="container footer-hours">
    <div>
      <span>Orari</span>
      <strong>Lun-Ven 8:30-12:30 / 15:30-19:00</strong>
    </div>
    <div>
      <span>Sabato</span>
      <strong>09:00-12:30</strong>
    </div>
    <div>
      <span>Domenica</span>
      <strong>Chiuso</strong>
    </div>
    <div>
      <span>Ragione sociale</span>
      <strong>{site.fullName}</strong>
    </div>
  </div>

  <div class="container footer-bottom">
    <span>© 2026 Buffetti Cucchi s.a.s. Tutti i diritti riservati.</span>

    <a href={site.developerUrl} target="_blank" rel="noopener noreferrer">
      Sito realizzato da Tommaso Bagnolini
      <ExternalLink size={18} stroke-width={2.2} class="cta-icon" style={{ marginLeft: "5px" }} />
    </a>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    overflow: hidden;
    padding: 0 0 34px;
    color: rgba(255, 255, 255, 0.78);
    background:
      radial-gradient(circle at 10% 8%, rgba(0, 166, 232, 0.2), transparent 28%),
      linear-gradient(135deg, #020716, #06142d 54%, #0000e8);
  }

  .footer::before {
    content: "";
    position: absolute;
    inset: 0;
    opacity: 0.16;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
    background-size: 26px 26px;
    pointer-events: none;
  }

  .footer-topline {
    position: relative;
    z-index: 1;
    height: 8px;
    background: #0000e8;
  }

  .footer-inner,
  .footer-hours,
  .footer-bottom {
    position: relative;
    z-index: 1;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.35fr 0.78fr 0.78fr 1fr;
    gap: 48px;
    padding: 76px 0 42px;
  }

  .footer-logo-row {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .footer-logo-row img {
    width: 92px;
    height: auto;
    filter: drop-shadow(0 14px 22px rgba(0, 0, 0, 0.35));
  }

  .footer-logo-row div {
    display: grid;
    gap: 2px;
  }

  .footer-logo-row strong,
  .footer-col h2 {
    color: #fff;
    font-size: 1.02rem;
    font-weight: 840;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .footer-logo-row span,
  .footer-contact-card > span,
  .footer-hours span {
    color: #9fe9ff;
    font-size: 0.76rem;
    font-weight: 840;
    text-transform: uppercase;
    letter-spacing: 0.09em;
  }

  .footer-brand p {
    max-width: 440px;
    margin: 30px 0 24px;
    color: rgba(255, 255, 255, 0.72);
    font-size: 1.02rem;
    line-height: 1.72;
  }

  .footer-social {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .footer-social a {
    min-height: 42px;
    padding: 0 13px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #001f45;
    background: #fff;
    border-radius: 4px;
    font-weight: 840;
  }

  .footer-social img {
    width: 18px;
    height: 18px;
  }

  .footer-col h2 {
    margin: 0 0 22px;
  }

  .footer-col nav {
    display: grid;
    gap: 12px;
  }

  .footer-col a {
    width: fit-content;
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.96rem;
    font-weight: 760;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .footer-col a:hover {
    color: #fff;
    transform: translateX(4px);
  }

  .footer-contact-card {
    padding: 26px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.08);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.22);
  }

  .footer-contact-card h2 {
    margin: 16px 0 22px;
    color: #fff;
    font-size: 1.7rem;
    line-height: 1.05;
    letter-spacing: -0.045em;
  }

  .footer-contact-card a {
    min-height: 42px;
    display: flex;
    align-items: center;
    gap: 10px;
    color: rgba(255, 255, 255, 0.82);
    font-weight: 760;
  }

  .footer-contact-card svg {
    color: #9fe9ff;
  }

  .footer-hours {
    display: grid;
    grid-template-columns: 1fr 0.6fr 0.6fr 1.2fr;
    gap: 1px;
    overflow: hidden;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.12);
  }

  .footer-hours div {
    padding: 18px;
    background: rgba(255, 255, 255, 0.07);
  }

  .footer-hours strong {
    display: block;
    margin-top: 6px;
    color: #fff;
    line-height: 1.3;
  }

  .footer-bottom {
    margin-top: 34px;
    padding-top: 28px;
    display: flex;
    justify-content: space-between;
    gap: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .footer-bottom span,
  .footer-bottom a {
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.92rem;
  }

  .footer-bottom a {
    font-weight: 760;
  }

  .footer-bottom a:hover {
    color: #fff;
  }

  @media (max-width: 1050px) {
    .footer-inner,
    .footer-hours {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 680px) {
    .footer-inner,
    .footer-hours {
      grid-template-columns: 1fr;
    }

    .footer-inner {
      padding-top: 58px;
    }

    .footer-bottom {
      flex-direction: column;
    }
  }
</style>
